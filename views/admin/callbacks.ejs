<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px; align-items: start;">
    
    <%- include('../partials/_admin_sidebar') %>
    
    <section>
        <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h1 style="font-size: 1.8rem;">Заявки на звонок</h1>
            </div>
            
           <% if (typeof success !== 'undefined' && success) { %>
    <div style="background: #d4edda; color: #155724; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
        <%= success %>
    </div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
    <div style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
        <%= error %>
    </div>
<% } %>
            
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: #f8f9fa; border-bottom: 2px solid #eee;">
                            <th style="padding: 12px;">ID</th>
                            <th style="padding: 12px;">Имя</th>
                            <th style="padding: 12px;">Телефон</th>
                            <th style="padding: 12px;">Статус</th>
                            <th style="padding: 12px;">Дата</th>
                            <th style="padding: 12px;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (callbacks && callbacks.length > 0) { %>
                            <% callbacks.forEach(callback => { %>
                                <tr style="border-bottom: 1px solid #eee;">
                                    <td style="padding: 12px;"><%= callback.id %></td>
                                    <td style="padding: 12px;"><%= callback.name %></td>
                                    <td style="padding: 12px;"><%= callback.phone %></td>
                                    <td style="padding: 12px;">
                                        <form action="/admin/callbacks/update-status/<%= callback.id %>" method="POST" style="display: flex; gap: 5px;">
                                            <select name="status" style="padding: 5px 10px; border-radius: 5px; border: 1px solid #ddd;">
                                                <option value="new" <%= callback.status === 'new' ? 'selected' : '' %>>Новая</option>
                                                <option value="processed" <%= callback.status === 'processed' ? 'selected' : '' %>>Обработана</option>
                                            </select>
                                            
                                        </form>
                                    </td>
                                    <td style="padding: 12px;"><%= new Date(callback.created_at).toLocaleString('ru-RU') %></td>
                                    <td style="padding: 12px;">
                                        <form action="/admin/callbacks/delete/<%= callback.id %>" method="POST" onsubmit="return confirm('Удалить заявку от <%= callback.name %>?')">
                                            <button type="submit" style="background: #dc3545; color: white; border: none; padding: 5px 12px; border-radius: 5px; cursor: pointer;">
                                                🗑️ Удалить
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" style="padding: 40px; text-align: center; color: #999;">
                                    Нет заявок на звонок
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
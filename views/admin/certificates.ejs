<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">
   
    <aside style="background: var(--black); color: white; padding: 20px; border-radius: 10px; height: fit-content;">
        <h3 style="color: var(--primary-blue); margin-bottom: 20px; font-size: 1.2rem;">Админ-панель</h3>
        <nav style="display: flex; flex-direction: column; gap: 15px;">
            <a href="/admin" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="layout-dashboard" size="18"></i> Главная</a>
            <a href="/admin/home" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="home" size="18"></i> Контент Главной</a>
            <a href="/admin/certificates" style="color: var(--primary-blue); font-weight: bold; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="file-text" size="18"></i> Сертификаты</a>
            <a href="/admin/services" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="settings" size="18"></i> Услуги</a>
            <a href="/admin/callbacks" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="phone-call" size="18"></i> Заявки на звонок</a>
            <a href="/admin/messages" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="mail"></i> Вопросы</a>
            <a href="/admin/projects" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="briefcase" size="18"></i> Наши работы</a>
            <a href="/admin/contacts" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="phone" size="18"></i> Контакты</a>
            <a href="/admin/content" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="file-text" size="18"></i> Тексты сайта</a>
            <hr style="border: 0; border-top: 1px solid #444; margin: 10px 0;">
            <a href="/" style="color: #ffb3b3; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="external-link" size="18"></i> На сайт</a>
        </nav>
    </aside>

    <section style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <h2>Сертификаты и лицензии</h2>
        <hr style="margin: 20px 0;">

        <% if (success) { %>
            <div style="background: #d4edda; color: #155724; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
                <% if (success == 1) { %>Сертификат добавлен<% } %>
                <% if (success == 2) { %>Сертификат обновлен<% } %>
                <% if (success == 3) { %>Сертификат удален<% } %>
            </div>
        <% } %>

        <% if (error) { %>
            <div style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 6px; margin-bottom: 20px;">
                Ошибка при выполнении операции
            </div>
        <% } %>

        <!-- Форма добавления -->
        <details open style="margin-bottom: 30px;">
            <summary style="cursor: pointer; font-weight: 600; font-size: 1.1rem; color: var(--primary-blue); margin-bottom: 15px;">+ Добавить сертификат</summary>
            <form action="/admin/certificates/add" method="POST" enctype="multipart/form-data" style="margin-top: 20px;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <label style="display: block; margin-bottom: 5px; font-weight: 500;">Название *</label>
                        <input type="text" name="title" required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
                    </div>
                    <div>
                        <label style="display: block; margin-bottom: 5px; font-weight: 500;">Фото (JPG/PNG) *</label>
                        <input type="file" name="image" accept="image/jpeg,image/jpg,image/png" required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
                    </div>
                </div>
                <div style="margin-top: 15px;">
                    <label style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                        <input type="checkbox" name="is_active" checked> Показывать на сайте
                    </label>
                </div>
                <button type="submit" class="btn btn-blue" style="margin-top: 20px;">Добавить</button>
            </form>
        </details>

        <!-- Список сертификатов -->
        <h3 style="margin-bottom: 15px;">Список сертификатов (<%= certificates.length %>)</h3>
        
        <div id="sortable-list" style="display: flex; flex-direction: column; gap: 15px;">
            <% certificates.forEach((cert) => { %>
                <div data-id="<%= cert.id %>" style="border: 1px solid #eee; border-radius: 10px; padding: 15px; background: #fafafa;">
                    <form action="/admin/certificates/update/<%= cert.id %>" method="POST" enctype="multipart/form-data" style="display: grid; grid-template-columns: 100px 1fr auto; gap: 15px; align-items: start;">
                        <div style="text-align: center;">
                            <% if (cert.image_url) { %>
                                <img src="/img/<%= cert.image_url %>" alt="<%= cert.title %>" style="width: 80px; height: auto; border-radius: 5px; border: 1px solid #ddd;">
                            <% } else { %>
                                <div style="width: 80px; height: 100px; background: #eee; display: flex; align-items: center; justify-content: center; border-radius: 5px;">нет фото</div>
                            <% } %>
                            <input type="file" name="image" accept="image/jpeg,image/jpg,image/png" style="width: 100%; margin-top: 8px; padding: 4px; font-size: 10px;">
                            <input type="hidden" name="existing_image" value="<%= cert.image_url %>">
                        </div>
                        <div>
                            <input type="text" name="title" value="<%= cert.title %>" required style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
                        </div>
                        <div style="text-align: right;">
                            <label style="display: flex; align-items: center; gap: 5px; margin-bottom: 10px; cursor: pointer;">
                                <input type="checkbox" name="is_active" <%= cert.is_active ? 'checked' : '' %>> Активен
                            </label>
                            <button type="submit" class="btn btn-blue" style="padding: 5px 15px; font-size: 12px; margin-bottom: 5px;">Сохранить</button>
                            <button type="button" onclick="deleteCert(<%= cert.id %>)" style="background: #dc3545; color: white; border: none; padding: 5px 15px; border-radius: 5px; cursor: pointer; font-size: 12px;">Удалить</button>
                            <div style="margin-top: 8px; cursor: move; color: #999; font-size: 11px;">⋮⋮ перетащить</div>
                        </div>
                    </form>
                </div>
            <% }) %>
        </div>
        
        <% if (certificates.length === 0) { %>
            <p style="color: #999; text-align: center; padding: 40px;">Нет добавленных сертификатов</p>
        <% } %>
    </section>
</main>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<script>
    const list = document.getElementById('sortable-list');
    if (list) {
        new Sortable(list, {
            animation: 150,
            onEnd: function() {
                const ids = [];
                document.querySelectorAll('#sortable-list > div').forEach(el => {
                    ids.push(el.dataset.id);
                });
                fetch('/admin/certificates/reorder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ order: ids })
                });
            }
        });
    }
    
    function deleteCert(id) {
        if (confirm('Удалить сертификат?')) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/admin/certificates/delete/' + id;
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>

<%- include('../partials/footer') %>
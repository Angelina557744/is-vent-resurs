<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">
   
       <%- include('../partials/_admin_sidebar') %>

    <section style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <h2>История диалогов с чат-ботом</h2>
        <hr style="margin: 20px 0;">
        
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #eee;">
                        <th style="padding: 12px;">Дата</th>
                        <th style="padding: 12px;">Имя</th>
                        <th style="padding: 12px;">Телефон</th>
                        <th style="padding: 12px;">Вопрос</th>
                        <th style="padding: 12px;">Ответ бота</th>
                        <th style="padding: 12px;">Нужен звонок</th>
                    </tr>
                </thead>
                <tbody>
                    <% messages.forEach(msg => { %>
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 12px; font-size: 0.8rem;"><%= new Date(msg.created_at).toLocaleString('ru-RU') %></td>
                            <td style="padding: 12px;"><%= msg.user_name || '-' %></td>
                            <td style="padding: 12px;"><%= msg.user_phone || '-' %></td>
                            <td style="padding: 12px; max-width: 250px;"><%= msg.user_message %></td>
                            <td style="padding: 12px; max-width: 300px; font-size: 0.85rem;"><%= msg.bot_response %></td>
                            <td style="padding: 12px; text-align: center;">
                                <% if (msg.need_call) { %>
                                    <span style="background: #ff9800; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem;">Да</span>
                                <% } else { %>
                                    <span style="background: #28a745; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem;">Нет</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <% if (messages.length === 0) { %>
            <p style="color: #999; text-align: center; padding: 40px;">Нет сообщений в чате</p>
        <% } %>
    </section>
</main>

<%- include('../partials/footer') %>
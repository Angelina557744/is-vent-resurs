<%- include('../partials/header') %>
<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">

    
      <%- include('../partials/_admin_sidebar') %>

    <section style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <h2>Управление текстами на сайте</h2>
        <form action="/admin/content/update" method="POST" style="margin-top: 20px;">
            <% settings.forEach(s => { %>
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 600; margin-bottom: 5px;"><%= s.description %></label>
                    <input type="text" name="<%= s.setting_key %>" value="<%= s.setting_value %>" 
                           style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; font-family: 'Cascadia Code';">
                </div>
            <% }) %>
            <button type="submit" class="btn btn-blue">Сохранить все изменения</button>
        </form>
    </section>
</main>
<%- include('../partials/footer') %>
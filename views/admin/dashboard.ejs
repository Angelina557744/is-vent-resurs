<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">
    <aside style="background: var(--black); color: white; padding: 20px; border-radius: 10px; height: fit-content;">
        <h3 style="color: var(--primary-blue); margin-bottom: 20px;">Админка</h3>
        <nav style="display: flex; flex-direction: column; gap: 15px;">
            <a href="/admin" style="color: white; text-decoration: none;"><i data-lucide="layout-dashboard"></i> Главная</a>
            <a href="/admin/services" style="color: #ccc; text-decoration: none;"><i data-lucide="settings"></i> Услуги</a>
            <a href="/admin/projects" style="color: #ccc; text-decoration: none;"><i data-lucide="clipboard-list"></i> Заказы</a>
            <a href="/admin/users" style="color: #ccc; text-decoration: none;"><i data-lucide="users"></i> Пользователи</a>
        </nav>
    </aside>

    <section>
        <div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
            <h2>Статистика системы</h2>
            <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
                <div style="background: var(--light-gray); padding: 20px; border-radius: 8px; border-top: 4px solid var(--primary-blue);">
                    <h4 style="color: var(--text-gray);">Пользователей</h4>
                    <p style="font-size: 2rem; font-weight: bold;"><%= stats.users %></p>
                </div>
                <div style="background: var(--light-gray); padding: 20px; border-radius: 8px; border-top: 4px solid var(--accent-color);">
                    <h4 style="color: var(--text-gray);">Всего заказов</h4>
                    <p style="font-size: 2rem; font-weight: bold;"><%= stats.projects %></p>
                </div>
            </div>

            <div style="margin-top: 40px; padding: 20px; background: #e7f3ff; border-radius: 8px; color: #004085;">
                <p><strong>Уведомление:</strong> Добро пожаловать в панель управления. Здесь вы можете изменять информацию об услугах и отслеживать статусы заявок клиентов.</p>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
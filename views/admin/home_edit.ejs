<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">
    <aside style="background: var(--black); color: white; padding: 20px; border-radius: 10px; height: fit-content;">
        <nav style="display: flex; flex-direction: column; gap: 15px;">
            <a href="/admin" style="color: #ccc; text-decoration: none;"><i data-lucide="layout-dashboard"></i> Dashboard</a>
           <a href="/admin/contacts" style="color: white; font-weight: bold;"><i data-lucide="phone"></i> Контакты</a>
            <a href="/admin/home" style="color: white; font-weight: bold;"><i data-lucide="home"></i> Главная страница</a>
            <a href="/admin/services" style="color: #ccc; text-decoration: none;"><i data-lucide="settings"></i> Услуги</a>
        </nav>
    </aside>

    <section style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <h2>Редактирование главной страницы</h2>
        <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

        <details open style="margin-bottom: 30px;">
            <summary style="cursor: pointer; font-weight: 600; font-size: 1.2rem; color: var(--primary-blue);">Основные тексты</summary>
            <form action="/admin/home/update-texts" method="POST" style="margin-top: 20px;">
                <% texts.forEach(text => { %>
                    <div style="margin-bottom: 15px;">
                        <label style="display: block; font-size: 0.9rem; margin-bottom: 5px; color: #666;"><%= text.description %></label>
                        <% if (text.setting_key.includes('text')) { %>
                            <textarea name="<%= text.setting_key %>" rows="5" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; font-family: 'Cascadia Code';"><%= text.setting_value %></textarea>
                        <% } else { %>
                            <input type="text" name="<%= text.setting_key %>" value="<%= text.setting_value %>" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; font-family: 'Cascadia Code';">
                        <% } %>
                    </div>
                <% }) %>
                <button type="submit" class="btn btn-blue">Сохранить тексты</button>
            </form>
        </details>

        <details style="margin-bottom: 30px;">
            <summary style="cursor: pointer; font-weight: 600; font-size: 1.2rem; color: var(--primary-blue);">Преимущества (6 карточек)</summary>
            <form action="/admin/home/update-advantages" method="POST" style="margin-top: 20px;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <% advantages.forEach(adv => { %>
                        <div style="padding: 15px; border: 1px solid #eee; border-radius: 8px; background: #fafafa;">
                            <input type="hidden" name="id[]" value="<%= adv.id %>">
                            <div style="margin-bottom: 10px;">
                                <label style="font-size: 0.8rem;">Иконка (напр. 'wrench', 'truck')</label>
                                <input type="text" name="icon_name[]" value="<%= adv.icon_name %>" style="width: 100%; padding: 5px;">
                            </div>
                            <div style="margin-bottom: 10px;">
                                <label style="font-size: 0.8rem;">Заголовок</label>
                                <input type="text" name="title[]" value="<%= adv.title %>" style="width: 100%; padding: 5px;">
                            </div>
                            <textarea name="description[]" rows="2" style="width: 100%; padding: 5px;"><%= adv.description %></textarea>
                        </div>
                    <% }) %>
                </div>
                <button type="submit" class="btn btn-blue" style="margin-top: 20px;">Обновить карточки</button>
            </form>
        </details>
    </section>

    <details style="margin-bottom: 30px;">
    <summary style="cursor: pointer; font-weight: 600; font-size: 1.2rem; color: var(--primary-blue);">Данные на странице Контакты</summary>
    <form action="/admin/home/update-texts" method="POST" style="margin-top: 20px;">
        <% texts.filter(t => t.category === 'contacts').forEach(text => { %>
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-size: 0.9rem; margin-bottom: 5px; color: #666;"><%= text.description %></label>
                <input type="text" name="<%= text.setting_key %>" value="<%= text.setting_value %>" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
            </div>
        <% }) %>
        <button type="submit" class="btn btn-blue">Обновить контакты</button>
    </form>
</details>

<div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-top: 30px;">
    <h3 style="color: var(--primary-blue); margin-bottom: 20px;">
        <i data-lucide="map-pin"></i> Управление страницей Контакты
    </h3>
    
    <form action="/admin/home/update-texts" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <% texts.filter(t => t.category === 'contacts').forEach(text => { %>
                <div style="margin-bottom: 15px;">
                    <label style="display: block; font-size: 0.85rem; margin-bottom: 5px; color: #666; font-weight: 600;">
                        <%= text.description %>
                    </label>
                    <input type="text" name="<%= text.setting_key %>" value="<%= text.setting_value %>" 
                           style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem;">
                </div>
            <% }) %>
        </div>
        
        <div style="margin-top: 20px; padding: 15px; background: #fff4e5; border-radius: 8px; font-size: 0.85rem; color: #663c00;">
            <strong>Как менять карту:</strong> Зайдите на Яндекс.Карты, найдите свой адрес, нажмите правой кнопкой мыши "Что здесь?" и скопируйте цифры (например, 51.815, 55.152) в поле "Координаты".
        </div>

        <button type="submit" class="btn btn-blue" style="margin-top: 20px; padding: 12px 30px;">
            Сохранить изменения контактов
        </button>
    </form>
</div>
</main>

<%- include('../partials/footer') %>
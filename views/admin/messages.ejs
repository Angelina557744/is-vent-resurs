<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px; margin-bottom: 50px;">
    
   <aside style="background: var(--black); color: white; padding: 20px; border-radius: 10px; height: fit-content; min-height: 400px;">
        <h3 style="color: var(--primary-blue); margin-bottom: 20px; font-size: 1.2rem;">Админ-панель</h3>
        <nav style="display: flex; flex-direction: column; gap: 15px;">
            <a href="/admin" style="color: white; font-weight: bold; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="layout-dashboard" size="18"></i> Главная</a>
            <a href="/admin/home" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="home" size="18"></i> Контент Главной</a>
            <a href="/admin/services" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="settings" size="18"></i> Услуги</a>
            <a href="/admin/callbacks" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="phone-call" size="18"></i> Заявки на звонок</a>
            <a href="/admin/messages" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="mail"></i> Вопросы</a>
            <a href="/admin/projects" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="briefcase" size="18"></i> Наши работы</a>
            <a href="/admin/contacts" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="phone" size="18"></i> Контакты</a>
            <a href="/admin/content" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="file-text" size="18"></i> Тексты сайта</a>
            <hr style="border: 0; border-top: 1px solid #444; margin: 10px 0;">
            <a href="/" style="color: #ffb3b3; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="external-link" size="18"></i> На сайт</a>
        </nav>
    </aside>

    <section style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h2 style="margin: 0; display: flex; align-items: center; gap: 12px;">
                <i data-lucide="inbox" style="color: var(--primary-blue);"></i> Вопросы пользователей
            </h2>
            <span style="background: #f0f7ff; color: var(--primary-blue); padding: 5px 15px; border-radius: 20px; font-size: 0.85rem; font-weight: bold;">
                Всего: <%= messages.length %>
            </span>
        </div>

        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; min-width: 800px;">
                <thead>
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #eee; text-align: left;">
                        <th style="padding: 15px; font-size: 0.9rem; color: #666;">Отправитель</th>
                        <th style="padding: 15px; font-size: 0.9rem; color: #666;">Сообщение</th>
                        <th style="padding: 15px; font-size: 0.9rem; color: #666;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (messages.length > 0) { %>
                        <% messages.forEach(msg => { %>
                            <tr style="border-bottom: 1px solid #eee; transition: background 0.2s;" onmouseover="this.style.background='#fcfdff'" onmouseout="this.style.background='transparent'">
                                <td style="padding: 15px; vertical-align: top;">
                                    <div style="font-weight: bold; color: #333;"><%= msg.name %></div>
                                    <div style="font-size: 0.85rem; color: #666; margin-top: 4px;">
                                        <i data-lucide="phone" size="12"></i> <%= msg.phone || '-' %><br>
                                        <i data-lucide="at-sign" size="12"></i> <span style="color: var(--primary-blue);"><%= msg.email %></span>
                                    </div>
                                    <div style="font-size: 0.75rem; color: #999; margin-top: 8px;">
                                        <i data-lucide="clock" size="12"></i> <%= new Date(msg.created_at).toLocaleString('ru-RU') %>
                                    </div>
                                </td>
                                <td style="padding: 15px;">
                                    <div style="background: #fdfdfd; border: 1px solid #f0f0f0; padding: 12px; border-radius: 8px; margin-bottom: 12px;">
                                        <strong style="font-size: 0.8rem; color: #888; text-transform: uppercase;">Текст вопроса:</strong>
                                        <p style="margin: 5px 0 0 0; font-size: 0.95rem; color: #333; line-height: 1.5;"><%= msg.message %></p>
                                    </div>
                                    
                                    <!-- МЕТКА ОТ ИИ -->
                                    <div style="margin-top: 8px;">
                                        <% 
                                            let catColor = '#666'; 
                                            let catBg = '#f5f5f5';
                                            const cat = msg.category || 'Общее';
                                            
                                            if(cat.includes('Ремонт')) { catColor = '#d32f2f'; catBg = '#ffebeb'; }
                                            else if(cat.includes('Проектирование')) { catColor = '#0277bd'; catBg = '#e6f4ff'; }
                                            else if(cat.includes('Сотрудничество')) { catColor = '#388e3c'; catBg = '#f6ffed'; }
                                            else if(cat.includes('Цена')) { catColor = '#f57c00'; catBg = '#fff3e0'; }
                                        %>
                                        <span style="
                                            display: inline-flex; 
                                            align-items: center; 
                                            gap: 5px; 
                                            padding: 3px 10px; 
                                            border-radius: 4px; 
                                            font-size: 0.7rem; 
                                            font-weight: bold;
                                            background: <%= catBg %>;
                                            color: <%= catColor %>;
                                            border: 1px solid <%= catColor %>40;">
                                            <i data-lucide="cpu" size="12"></i>
                                            ИИ: <%= cat %>
                                        </span>
                                    </div>

                                    <% if (msg.admin_answer) { %>
                                        <div style="margin-top: 12px; background: #f0f7ff; padding: 10px; border-radius: 6px; border-left: 3px solid var(--primary-blue);">
                                            <strong style="font-size: 0.75rem; color: var(--primary-blue);">Ваш ответ:</strong>
                                            <p style="margin: 5px 0 0 0; font-size: 0.85rem; color: #555;"><%= msg.admin_answer %></p>
                                        </div>
                                    <% } %>
                                </td>
                                <td style="padding: 15px; vertical-align: top;">
                                    <form action="/admin/messages/answer/<%= msg.id %>" method="POST">
                                        <textarea name="admin_answer" placeholder="Напишите ответ пользователю..." required 
                                                  style="width: 100%; min-height: 100px; padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 0.85rem; resize: vertical; margin-bottom: 8px;"><%= msg.admin_answer || '' %></textarea>
                                        <button type="submit" class="btn btn-blue" style="width: 100%; padding: 8px; font-size: 0.8rem;">
                                            <%= msg.admin_answer ? 'Обновить ответ' : 'Отправить ответ' %>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" style="padding: 60px; text-align: center; color: #999;">Сообщений пока нет</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </section>
</main>

<style>
    .btn-blue {
        background: var(--primary-blue);
        color: white;
        border: none;
        cursor: pointer;
        transition: 0.3s opacity;
        border-radius: 6px;
    }
    .btn-blue:hover {
        opacity: 0.9;
    }
</style>

<%- include('../partials/footer') %>
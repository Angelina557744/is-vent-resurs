<%- include('../partials/header') %>

<div class="admin-container">
    <div class="admin-header">
        <h1>Редактирование: <%= project.title %></h1>
        <a href="/admin/projects" class="btn btn-outline">← Назад к списку</a>
    </div>
    
    <% if (success) { %>
        <div class="alert alert-success">Сохранено успешно!</div>
    <% } %>
    <% if (error) { %>
        <div class="alert alert-error">Ошибка при сохранении</div>
    <% } %>
    
    <form action="/admin/projects/<%= project.id %>/detail/save" method="POST" class="admin-form">
        <div class="form-section">
            <h3>Основная информация</h3>
            
            <div class="form-group">
                <label>Год</label>
                <input type="number" name="year" value="<%= project.year %>" required>
            </div>
            
            <div class="form-group">
                <label>Заголовок</label>
                <input type="text" name="title" value="<%= projectDetail ? projectDetail.title : project.title %>" required>
            </div>
            
            <div class="form-group">
                <label>Детальное описание</label>
                <textarea name="description" rows="10" class="editor"><%= projectDetail ? projectDetail.description : '' %></textarea>
            </div>
        </div>
        
        <button type="submit" class="btn btn-primary">Сохранить изменения</button>
    </form>
    
    <div class="form-section">
        <h3>Хронология работ</h3>
        
        <form action="/admin/projects/timeline/add" method="POST" class="inline-form">
            <input type="hidden" name="project_detail_id" value="<%= projectDetail ? projectDetail.id : '' %>">
            
            <div class="form-row">
                <div class="form-group">
                    <label>Дата (Месяц Год)</label>
                    <input type="text" name="month_date" placeholder="Сентябрь 2023" required>
                </div>
                <div class="form-group">
                    <label>Заголовок (опционально)</label>
                    <input type="text" name="title" placeholder="Например: Начало работ">
                </div>
            </div>
            
            <div class="form-group">
                <label>Содержание</label>
                <textarea name="content" rows="4" required></textarea>
            </div>
            
            <div class="form-group">
                <label>Порядок отображения</label>
                <input type="number" name="display_order" value="0">
            </div>
            
            <button type="submit" class="btn btn-primary">+ Добавить событие</button>
        </form>
        
        <% if (timeline && timeline.length > 0) { %>
            <div class="items-list">
                <h4>Существующие события:</h4>
                <% timeline.forEach(item => { %>
                    <div class="item-card">
                        <div class="item-info">
                            <strong><%= item.month_date %></strong>
                            <% if (item.title) { %>
                                <span>— <%= item.title %></span>
                            <% } %>
                        </div>
                        <form action="/admin/projects/timeline/<%= item.id %>/delete" method="POST" class="delete-form">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Удалить?')">Удалить</button>
                        </form>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
    
    <div class="form-section">
        <h3>Фотогалерея</h3>
        
        <form action="/admin/projects/photos/add" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="project_detail_id" value="<%= projectDetail ? projectDetail.id : '' %>">
            
            <div class="form-group">
                <label>Изображение</label>
                <input type="file" name="image" accept="image/*" required>
            </div>
            
            <div class="form-group">
                <label>Подпись</label>
                <input type="text" name="title" placeholder="Краткое описание фото">
            </div>
            
            <div class="form-group">
                <label>Порядок отображения</label>
                <input type="number" name="display_order" value="0">
            </div>
            
            <button type="submit" class="btn btn-primary">+ Добавить фото</button>
        </form>
        
        <% if (photos && photos.length > 0) { %>
            <div class="photos-grid">
                <h4>Существующие фото:</h4>
                <div class="photo-list">
                    <% photos.forEach(photo => { %>
                        <div class="photo-item">
                            <img src="/img/<%= photo.image_url %>" alt="<%= photo.title %>" style="width: 100px; height: 100px; object-fit: cover;">
                            <div class="photo-info">
                                <div><%= photo.title || 'Без подписи' %></div>
                                <form action="/admin/projects/photos/<%= photo.id %>/delete" method="POST" class="delete-form">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Удалить фото?')">Удалить</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    </div>
</div>

<style>
.admin-container {
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 20px;
}

.admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 2px solid #eee;
}

.form-section {
    background: white;
    padding: 30px;
    border-radius: 16px;
    margin-bottom: 30px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
}

.form-section h3 {
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid #007bff;
    display: inline-block;
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
}

.form-group input,
.form-group textarea,
.form-group select {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 1rem;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.inline-form {
    background: #f8f9fa;
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 30px;
}

.items-list {
    margin-top: 30px;
}

.item-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    background: #f8f9fa;
    margin-bottom: 10px;
    border-radius: 8px;
}

.photos-grid {
    margin-top: 30px;
}

.photo-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.photo-item {
    background: #f8f9fa;
    border-radius: 8px;
    overflow: hidden;
    text-align: center;
}

.photo-info {
    padding: 10px;
}

.alert {
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
}

.alert-success {
    background: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}

.alert-error {
    background: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}

.btn-sm {
    padding: 5px 10px;
    font-size: 0.8rem;
}

.delete-form {
    display: inline;
}
</style>

<%- include('../partials/footer') %>
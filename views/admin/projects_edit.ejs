<%- include('../partials/header') %>

<main class="admin-main">
    <div class="admin-sidebar">
        <%- include('../partials/_admin_sidebar') %>
    </div>

    <div class="admin-content">
        <div class="admin-card">
            <div class="admin-card-header">
                <div>
                    <h2>Управление проектами</h2>
                    <p class="admin-card-subtitle">Добавление и редактирование портфолио компании</p>
                </div>
                <button class="admin-btn-primary" onclick="document.getElementById('add-project-form').style.display='flex'">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Добавить проект
                </button>
            </div>

            <div id="add-project-form" class="admin-modal" style="display: none;">
                <div class="admin-modal-content">
                    <div class="admin-modal-header">
                        <h3>Новый проект</h3>
                        <button class="admin-modal-close" onclick="document.getElementById('add-project-form').style.display='none'">×</button>
                    </div>
                    <form action="/admin/projects/add" method="POST">
                        <div class="admin-form-grid">
                            <div class="admin-form-group">
                                <label>Год</label>
                                <input type="number" name="year" placeholder="2024" required>
                            </div>
                            <div class="admin-form-group">
                                <label>Заголовок</label>
                                <input type="text" name="title" placeholder="Работа компании в 2024 году" required>
                            </div>
                            <div class="admin-form-group full-width">
                                <label>Тип объекта</label>
                                <input type="text" name="object_type" placeholder="Заводы, ТЦ, Больницы">
                            </div>
                            <div class="admin-form-group full-width">
                                <label>SEO Slug (url)</label>
                                <input type="text" name="slug" placeholder="rabota-kompanii-2024">
                            </div>
                            <div class="admin-form-group full-width">
                                <label>Картинка</label>
                                <input type="text" name="image_url" placeholder="project-2024.jpg">
                                <small>Файл должен быть в папке public/img/</small>
                            </div>
                        </div>
                        <div class="admin-modal-footer">
                            <button type="button" class="admin-btn-secondary" onclick="document.getElementById('add-project-form').style.display='none'">Отмена</button>
                            <button type="submit" class="admin-btn-primary">Сохранить</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="admin-table-wrapper">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Год</th>
                            <th>Название проекта</th>
                            <th>Тип объектов</th>
                            <th style="text-align: center;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (projects && projects.length > 0) { %>
                            <% projects.forEach(project => { %>
                                <tr>
                                    <td class="admin-year-badge"><%= project.year %></td>
                                    <td><strong><%= project.title %></strong></td>
                                    <td><span class="admin-type-tag"><%= project.object_type || '—' %></span></td>
                                    <td class="admin-actions">
                                        <a href="/admin/projects/<%= project.id %>/detail" class="admin-btn-icon" title="Редактировать">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M17 3l4 4-7 7H10v-4l7-7z"></path>
                                                <path d="M4 20h16"></path>
                                            </svg>
                                        </a>
                                        <form action="/admin/projects/delete/<%= project.id %>" method="POST" onsubmit="return confirm('Удалить проект? Все данные будут потеряны!')" style="display: inline;">
                                            <button type="submit" class="admin-btn-icon danger" title="Удалить">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"></polyline>
                                                    <path d="M8 6V4h8v2"></path>
                                                    <rect x="5" y="6" width="14" height="15" rx="2"></rect>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" style="text-align: center; padding: 60px;">
                                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                        <line x1="9" y1="9" x2="15" y2="15"></line>
                                        <line x1="15" y1="9" x2="9" y2="15"></line>
                                    </svg>
                                    <p style="color: #999; margin-top: 15px;">Нет добавленных проектов</p>
                                    <button class="admin-btn-primary" style="margin-top: 15px;" onclick="document.getElementById('add-project-form').style.display='flex'">Добавить первый проект</button>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<style>
.admin-main {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 30px;
    max-width: 1400px;
    margin: 40px auto;
    padding: 0 20px;
}

.admin-sidebar {
    position: sticky;
    top: 140px;
    height: fit-content;
}

.admin-content {
    min-width: 0;
}

.admin-card {
    background: white;
    border-radius: 20px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.05);
    overflow: hidden;
}

.admin-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 25px 30px;
    background: linear-gradient(135deg, #f8f9fa 0%, white 100%);
    border-bottom: 1px solid #eef2f6;
}

.admin-card-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 5px;
}

.admin-card-subtitle {
    font-size: 0.85rem;
    color: #888;
}

.admin-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #007bff, #0056b3);
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
}

.admin-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,123,255,0.3);
}

.admin-btn-secondary {
    background: #f0f0f0;
    color: #666;
    border: none;
    padding: 10px 20px;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s;
}

.admin-btn-secondary:hover {
    background: #e0e0e0;
}

.admin-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.admin-modal-content {
    background: white;
    border-radius: 24px;
    width: 90%;
    max-width: 600px;
    max-height: 90vh;
    overflow-y: auto;
}

.admin-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 25px;
    border-bottom: 1px solid #eee;
}

.admin-modal-header h3 {
    font-size: 1.3rem;
    font-weight: 600;
}

.admin-modal-close {
    background: none;
    border: none;
    font-size: 28px;
    cursor: pointer;
    color: #999;
}

.admin-modal-close:hover {
    color: #333;
}

.admin-form-grid {
    padding: 25px;
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.admin-form-group {
    display: flex;
    flex-direction: column;
    gap: 5px;
}

.admin-form-group.full-width {
    grid-column: span 2;
}

.admin-form-group label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #333;
}

.admin-form-group input {
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.3s;
}

.admin-form-group input:focus {
    outline: none;
    border-color: #007bff;
    box-shadow: 0 0 0 3px rgba(0,123,255,0.1);
}

.admin-form-group small {
    font-size: 0.7rem;
    color: #999;
}

.admin-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 20px 25px;
    border-top: 1px solid #eee;
}

.admin-table-wrapper {
    overflow-x: auto;
}

.admin-table {
    width: 100%;
    border-collapse: collapse;
}

.admin-table thead tr {
    background: #f8f9fa;
    border-bottom: 2px solid #eef2f6;
}

.admin-table th {
    padding: 15px 20px;
    text-align: left;
    font-size: 0.8rem;
    font-weight: 600;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.admin-table td {
    padding: 15px 20px;
    border-bottom: 1px solid #f0f0f0;
    vertical-align: middle;
}

.admin-year-badge {
    font-weight: 700;
    font-size: 1.1rem;
    color: #007bff;
}

.admin-type-tag {
    display: inline-block;
    background: #f0f0f0;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    color: #666;
}

.admin-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
}

.admin-btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: #f0f0f0;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    color: #007bff;
}

.admin-btn-icon:hover {
    background: #007bff;
    color: white;
}

.admin-btn-icon.danger:hover {
    background: #dc3545;
    color: white;
}

@media (max-width: 768px) {
    .admin-main {
        grid-template-columns: 1fr;
    }
    
    .admin-sidebar {
        position: static;
    }
    
    .admin-card-header {
        flex-direction: column;
        gap: 15px;
        text-align: center;
    }
}
</style>

<%- include('../partials/footer') %>
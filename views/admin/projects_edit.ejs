<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">

      <%- include('../partials/_admin_sidebar') %>

    <section>
        <div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>Управление проектами (Портфолио)</h2>
                <button onclick="document.getElementById('add-project-form').style.display='block'" class="btn btn-blue">+ Добавить год/проект</button>
            </div>

            <div id="add-project-form" style="display: none; background: #f9f9f9; padding: 20px; border-radius: 10px; margin-bottom: 30px; border: 1px solid #eee;">
                <h3 style="margin-bottom: 15px;">Новый проект</h3>
                <form action="/admin/projects/add" method="POST" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <label style="display:block; font-size: 0.8rem; margin-bottom: 5px;">Год (например: 2024)</label>
                        <input type="number" name="year" required style="width:100%; padding:10px; border:1px solid #ddd; border-radius:5px;">
                    </div>
                    <div>
                        <label style="display:block; font-size: 0.8rem; margin-bottom: 5px;">Заголовок</label>
                        <input type="text" name="title" placeholder="Работа компании в 2024 году" required style="width:100%; padding:10px; border:1px solid #ddd; border-radius:5px;">
                    </div>
                    <div style="grid-column: span 2;">
                        <label style="display:block; font-size: 0.8rem; margin-bottom: 5px;">Тип объекта (через запятую)</label>
                        <input type="text" name="object_type" placeholder="Заводы, ТЦ, Больницы" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:5px;">
                    </div>
                    <div style="grid-column: span 2;">
                        <label style="display:block; font-size: 0.8rem; margin-bottom: 5px;">Название файла картинки (в папке public/img/)</label>
                        <input type="text" name="image_url" placeholder="project-2024.jpg" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:5px;">
                    </div>
                    <div style="grid-column: span 2; display: flex; gap: 10px;">
                        <button type="submit" class="btn btn-blue">Сохранить</button>
                        <button type="button" onclick="document.getElementById('add-project-form').style.display='none'" class="btn btn-outline">Отмена</button>
                    </div>
                </form>
            </div>

            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f4f4f4; text-align: left;">
                        <th style="padding: 12px; border-bottom: 2px solid #eee;">Год</th>
                        <th style="padding: 12px; border-bottom: 2px solid #eee;">Название</th>
                        <th style="padding: 12px; border-bottom: 2px solid #eee;">Тип объектов</th>
                        <th style="padding: 12px; border-bottom: 2px solid #eee; text-align: right;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% projects.forEach(project => { %>
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 12px;"><strong><%= project.year %></strong></td>
                            <td style="padding: 12px;"><%= project.title %></td>
                            <td style="padding: 12px; font-size: 0.85rem; color: #666;"><%= project.object_type %></td>
                            <td style="padding: 12px; text-align: right;">
                                <form action="/admin/projects/delete/<%= project.id %>" method="POST" onsubmit="return confirm('Вы уверены, что хотите удалить этот проект?')">
                                    <button type="submit" style="background: none; border: none; color: #ff4d4d; cursor: pointer;">
                                        <i data-lucide="trash-2" size="18"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; margin-bottom: 50px;">
    <div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <h2>Редактирование услуги: <%= service.title %></h2>
        <hr style="margin: 20px 0;">
        
        <% if (error) { %>
            <div style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 6px; margin-bottom: 20px;">Ошибка при сохранении</div>
        <% } %>
        
        <form action="/admin/services/update/<%= service.id %>" method="POST">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div>
                    <label style="display: block; margin-bottom: 5px; font-weight: bold;">Название услуги *</label>
                    <input type="text" name="title" value="<%= service.title %>" required style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
                </div>

            </div>
            
            <div style="margin-top: 15px;">
                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Краткое описание (для карточки)</label>
                <textarea name="description" rows="3" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;"><%= service.description %></textarea>
            </div>
            
            <div style="margin-top: 15px;">
                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Полное описание</label>
                <textarea name="full_description" rows="10" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;"><%= service.full_description || '' %></textarea>
                <small style="color: #666;">Поддерживает HTML и переносы строк</small>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 15px;">
                <div>
                    <label style="display: block; margin-bottom: 5px; font-weight: bold;">Главное фото</label>
                    <input type="text" name="image_url" value="<%= service.image_url %>" placeholder="service.jpg" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
                    <small>Файл в папке /img/</small>
                </div>
               <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 15px;">
    <div>
        <label style="display: block; margin-bottom: 5px; font-weight: bold;">Главное фото</label>
        <input type="file" name="main_image" accept="image/*" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
        <small>Загрузите новое фото</small>
        <% if (service.image_url) { %>
            <div style="margin-top: 8px;">
                <img src="/img/<%= service.image_url %>" style="max-width: 80px; border-radius: 5px;">
                <span style="font-size: 12px; color: #666;">Текущее: <%= service.image_url %></span>
            </div>
        <% } %>
    </div>
    <div>
        <label style="display: block; margin-bottom: 5px; font-weight: bold;">Дополнительные фото</label>
        <input type="file" name="additional_images" accept="image/*" multiple style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
        <small>Выберите несколько фото</small>
        <% if (additionalImages && additionalImages.length > 0) { %>
            <div style="margin-top: 8px; display: flex; gap: 8px; flex-wrap: wrap;">
                <% additionalImages.forEach(img => { %>
                    <div style="position: relative;">
                        <img src="/img/<%= img %>" style="max-width: 60px; border-radius: 5px;">
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
            </div>
            
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 15px;">
                <div>
                    <label style="display: block; margin-bottom: 5px; font-weight: bold;">Заголовок</label>
                    <input type="text" name="seo_title" value="<%= service.seo_title || service.title %>" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 5px; font-weight: bold;">Описание</label>
                    <input type="text" name="seo_description" value="<%= service.seo_description || service.description %>" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
                </div>
            </div>
            
            <div style="margin-top: 30px; display: flex; gap: 15px;">
                <button type="submit" class="btn btn-blue" style="padding: 12px 30px;">Сохранить изменения</button>
                <a href="/admin/services" class="btn" style="background: #6c757d; color: white; padding: 12px 30px; text-decoration: none; border-radius: 5px;">Отмена</a>
            </div>
        </form>
        
        <hr style="margin: 30px 0;">
        
        <h3>Предпросмотр главного фото</h3>
        <% if (service.image_url) { %>
            <img src="/img/<%= service.image_url %>" alt="<%= service.title %>" style="max-width: 200px; border-radius: 10px; margin-top: 10px;">
        <% } else { %>
            <p style="color: #999;">Нет фото</p>
        <% } %>
    </div>
</main>

<script>
    // Преобразование строки с запятыми в JSON при отправке формы
    const form = document.querySelector('form');
    if (form) {
        form.addEventListener('submit', function(e) {
            const imagesInput = document.getElementById('imagesInput');
            if (imagesInput && imagesInput.value.trim()) {
                const images = imagesInput.value.split(',').map(i => i.trim()).filter(i => i);
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'images_json';
                hiddenInput.value = JSON.stringify(images);
                form.appendChild(hiddenInput);
                
                // Отключаем оригинальный input, чтобы не отправлялся
                imagesInput.disabled = true;
            }
        });
    }
</script>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px; margin-bottom: 50px;">
    
    <%- include('../partials/_admin_sidebar') %>

    <section style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h2 style="margin: 0; display: flex; align-items: center; gap: 12px;">
                <i data-lucide="shopping-cart" style="color: var(--primary-blue);"></i> Заявки на услуги
            </h2>
            <span style="background: #f0f7ff; color: var(--primary-blue); padding: 5px 15px; border-radius: 20px; font-size: 0.85rem;">
                Всего: <%= orders.length %>
            </span>
        </div>
        
        <% if (success) { %>
            <div style="background: #d4edda; color: #155724; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
                <%= success %>
            </div>
        <% } %>
        
        <% if (error) { %>
            <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
                <%= error %>
            </div>
        <% } %>
        
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #eee;">
                        <th style="padding: 12px; text-align: left;">ID</th>
                        <th style="padding: 12px; text-align: left;">Клиент</th>
                        <th style="padding: 12px; text-align: left;">Услуга</th>
                        <th style="padding: 12px; text-align: left;">Статус</th>
                        <th style="padding: 12px; text-align: left;">Дата</th>
                        <th style="padding: 12px; text-align: center;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (orders && orders.length > 0) { %>
                        <% orders.forEach(order => { 
                            let statusLabel = '';
                            let statusColor = '';
                            
                            switch(order.status) {
                                case 'new': 
                                    statusLabel = 'Новая'; 
                                    statusColor = '#ff9800';
                                    break;
                                case 'approved': 
                                    statusLabel = 'Одобрена'; 
                                    statusColor = '#28a745';
                                    break;
                                case 'rejected': 
                                    statusLabel = 'Отклонена'; 
                                    statusColor = '#dc3545';
                                    break;
                                default: 
                                    statusLabel = order.status; 
                                    statusColor = '#6c757d';
                            }
                        %>
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding: 12px;">#<%= order.id %></td>
                                <td style="padding: 12px;">
                                    <strong><%= order.name %></strong><br>
                                    <small style="color: #888;"><%= order.email %></small><br>
                                    <small style="color: #aaa;"><%= order.phone %></small>
                                 </td>
                                <td style="padding: 12px;">
                                    <%= order.service_title %>
                                    <% if (order.comment) { %>
                                        <br><small style="color: #888;">Комментарий: <%= order.comment %></small>
                                    <% } %>
                                 </td>
                                <td style="padding: 12px;">
                                    <span style="display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 500; background: <%= statusColor %>20; color: <%= statusColor %>;">
                                        <%= statusLabel %>
                                    </span>
                                    <% if (order.project_id) { %>
                                        <br><a href="/admin/user-projects/<%= order.project_id %>" style="font-size: 0.7rem;">Проект #<%= order.project_id %></a>
                                    <% } %>
                                 </td>
                                <td style="padding: 12px; font-size: 0.8rem; color: #888;">
                                    <%= new Date(order.created_at).toLocaleDateString('ru-RU') %>
                                </td>
                                <td style="padding: 12px; text-align: center;">
                                    <% if (order.status === 'new') { %>
                                        <form action="/admin/service-orders/<%= order.id %>/approve" method="POST" style="display: inline-block; margin-right: 5px;">
                                            <button type="submit" style="background: #28a745; color: white; border: none; padding: 6px 12px; border-radius: 5px; cursor: pointer; font-size: 0.7rem;">Одобрить и создать проект</button>
                                        </form>
                                        <form action="/admin/service-orders/<%= order.id %>/reject" method="POST" style="display: inline-block; margin-right: 5px;">
                                            <button type="submit" style="background: #ff9800; color: white; border: none; padding: 6px 12px; border-radius: 5px; cursor: pointer; font-size: 0.7rem;">Отклонить</button>
                                        </form>
                                    <% } %>
                                    <form action="/admin/service-orders/<%= order.id %>/delete" method="POST" onsubmit="return confirm('Удалить заявку?')" style="display: inline-block;">
                                        <button type="submit" style="background: #dc3545; color: white; border: none; padding: 6px 12px; border-radius: 5px; cursor: pointer; font-size: 0.7rem;">Удалить</button>
                                    </form>
                                 </td>
                             </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="padding: 50px; text-align: center; color: #999;">
                                <i data-lucide="shopping-cart" size="48" style="color: #ddd; margin-bottom: 10px;"></i>
                                <p>Нет заявок на услуги</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
             </table>
        </div>
    </section>
</main>

<script>
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>

<%- include('../partials/footer') %>
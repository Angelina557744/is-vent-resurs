<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">


        <aside style="background: var(--black); color: white; padding: 20px; border-radius: 10px; height: fit-content; min-height: 400px;">
        <h3 style="color: var(--primary-blue); margin-bottom: 20px; font-size: 1.2rem;">Админ-панель</h3>
        <nav style="display: flex; flex-direction: column; gap: 15px;">
            <a href="/admin" style="color: white; font-weight: bold; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="layout-dashboard" size="18"></i> Главная</a>
            <a href="/admin/home" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="home" size="18"></i> Контент Главной</a>
            <a href="/admin/services" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="settings" size="18"></i> Услуги</a>
            <a href="/admin/callbacks" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="phone-call" size="18"></i> Заявки на звонок</a>
            <a href="/admin/projects" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="briefcase" size="18"></i> Наши работы</a>
            <a href="/admin/contacts" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="phone" size="18"></i> Контакты</a>
            <a href="/admin/content" style="color: #ccc; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="file-text" size="18"></i> Тексты сайта</a>
            <hr style="border: 0; border-top: 1px solid #444; margin: 10px 0;">
            <a href="/" style="color: #ffb3b3; text-decoration: none; display: flex; align-items: center; gap: 10px;"><i data-lucide="external-link" size="18"></i> На сайт</a>
        </nav>
    </aside>

    <section>
        <div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>Управление услугами</h2>
                <button onclick="document.getElementById('add-form').style.display='block'" class="btn btn-blue">+ Добавить новую</button>
            </div>

            <div id="add-form" style="display:none; background: #f4f7f6; padding: 20px; border-radius: 8px; margin-bottom: 30px; border: 1px dashed var(--primary-blue);">
                <form action="/admin/services/add" method="POST">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <input type="text" name="title" placeholder="Название услуги" required style="padding: 10px; border-radius: 4px; border: 1px solid #ddd;">
                        <input type="text" name="image_url" placeholder="Имя файла картинки (напр. srv1.jpg)" style="padding: 10px; border-radius: 4px; border: 1px solid #ddd;">
                        <textarea name="description" placeholder="Краткое описание" style="grid-column: span 2; padding: 10px; border-radius: 4px; border: 1px solid #ddd;"></textarea>
                    </div>
                    <div style="margin-top: 15px;">
                        <button type="submit" class="btn btn-blue">Создать услугу</button>
                        <button type="button" onclick="document.getElementById('add-form').style.display='none'" class="btn btn-outline">Отмена</button>
                    </div>
                </form>
            </div>

            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: var(--light-gray); text-align: left; border-bottom: 2px solid #eee;">
                        <th style="padding: 15px;">Название</th>
                        <th style="padding: 15px; text-align: center;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% services.forEach(service => { %>
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 15px; font-weight: 500;"><%= service.title %></td>
                            <td style="padding: 15px; text-align: center; display: flex; justify-content: center; gap: 10px;">
                                <form action="/admin/services/delete/<%= service.id %>" method="POST" onsubmit="return confirm('Вы уверены?')">
                                    <button type="submit" style="background:none; border:none; color:#dc3545; cursor:pointer;">
                                        <i data-lucide="trash-2" size="18"></i> Удалить
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
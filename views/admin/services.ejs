<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">
    <aside style="background: var(--black); color: white; padding: 20px; border-radius: 10px; height: fit-content;">
        <nav style="display: flex; flex-direction: column; gap: 15px;">
            <a href="/admin" style="color: #ccc; text-decoration: none;"><i data-lucide="layout-dashboard"></i> Главная</a>
            <a href="/admin/services" style="color: white; text-decoration: none;"><i data-lucide="settings"></i> Услуги</a>
            <a href="/admin/projects" style="color: #ccc; text-decoration: none;"><i data-lucide="clipboard-list"></i> Заказы</a>
        </nav>
    </aside>

    <section>
        <div style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>Управление услугами</h2>
                <button onclick="document.getElementById('add-form').style.display='block'" class="btn btn-blue">+ Добавить услугу</button>
            </div>

            <div id="add-form" style="display:none; background: var(--light-gray); padding: 20px; border-radius: 8px; margin-bottom: 30px;">
                <form action="/admin/services/add" method="POST">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <input type="text" name="title" placeholder="Название услуги" required class="form-control" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                        <input type="number" name="price" placeholder="Цена (руб)" required class="form-control" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                        <input type="text" name="image_url" placeholder="URL иконки/картинки" class="form-control" style="padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                        <textarea name="description" placeholder="Описание" style="grid-column: span 2; padding: 10px; border: 1px solid #ccc; border-radius: 4px;"></textarea>
                    </div>
                    <div style="margin-top: 15px;">
                        <button type="submit" class="btn btn-blue">Сохранить</button>
                        <button type="button" onclick="document.getElementById('add-form').style.display='none'" class="btn">Отмена</button>
                    </div>
                </form>
            </div>

            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: var(--light-gray); text-align: left;">
                        <th style="padding: 12px;">Название</th>
                        <th style="padding: 12px;">Цена</th>
                        <th style="padding: 12px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% services.forEach(service => { %>
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 12px;"><%= service.title %></td>
                            <td style="padding: 12px;"><%= service.price %> руб.</td>
                            <td style="padding: 12px;">
                                <form action="/admin/services/delete/<%= service.id %>" method="POST" onsubmit="return confirm('Удалить?')">
                                    <button type="submit" style="background:none; border:none; color:red; cursor:pointer;">
                                        <i data-lucide="trash-2"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
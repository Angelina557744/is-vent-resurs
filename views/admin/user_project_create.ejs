<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px; margin-bottom: 50px;">
    
<%- include('../partials/_admin_sidebar') %>

    <section style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
        
        <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 25px;">
            <a href="/admin/user-projects" style="background: #6c757d; color: white; padding: 6px 12px; border-radius: 6px; text-decoration: none; font-size: 0.85rem;">
                ← Назад
            </a>
            <h2 style="margin: 0; display: flex; align-items: center; gap: 12px;">
                <i data-lucide="folder-plus" style="color: var(--primary-blue);"></i> Создание проекта
            </h2>
        </div>
        
        <% if (error) { %>
            <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
                <%= error %>
            </div>
        <% } %>
        
        <form action="/admin/user-projects/create" method="POST">
            <!-- Выбор пользователя -->
            <div style="margin-bottom: 25px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #333;">Клиент *</label>
                <select name="user_id" required style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'CascadiaCode', monospace;">
                    <option value="">-- Выберите клиента --</option>
                    <% users.forEach(user => { %>
                        <option value="<%= user.id %>"><%= user.full_name %> (<%= user.email %>)</option>
                    <% }) %>
                </select>
                <small style="color: #888;">Если клиента нет в списке, сначала <a href="/admin/users" style="color: var(--primary-blue);">создайте пользователя</a></small>
            </div>
            
            <!-- Выбор услуги -->
            <div style="margin-bottom: 25px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #333;">Услуга (необязательно)</label>
                <select name="service_id" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'CascadiaCode', monospace;">
                    <option value="">-- Не выбрано --</option>
                    <% services.forEach(service => { %>
                        <option value="<%= service.id %>"><%= service.title %></option>
                    <% }) %>
                </select>
            </div>
            
            <!-- Название проекта -->
            <div style="margin-bottom: 25px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #333;">Название проекта *</label>
                <input type="text" name="title" required placeholder="Например: Монтаж вентиляции в ТЦ «Европейский»" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'CascadiaCode', monospace;">
            </div>
            
            <!-- Адрес объекта -->
            <div style="margin-bottom: 25px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #333;">Адрес объекта</label>
                <input type="text" name="address" placeholder="г. Оренбург, ул. Примерная, д. 123" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'CascadiaCode', monospace;">
            </div>
            
            <!-- Статус проекта -->
            <div style="margin-bottom: 25px;">
                <label style="display: block; margin-bottom: 8px; font-weight: 600; color: #333;">Начальный статус</label>
                <select name="status" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-family: 'CascadiaCode', monospace;">
                    <option value="awaiting_approval">Ожидание одобрения заявки</option>
                    <option value="approved" selected>Одобрено (начало работ)</option>
                    <option value="design">Проектирование</option>
                    <option value="supply">Поставка оборудования</option>
                    <option value="installation">Монтажные работы</option>
                    <option value="commissioning">Пусконаладка</option>
                    <option value="completed">Работы завершены</option>
                </select>
                <small style="color: #888;">Статус «Одобрено» рекомендуется для проектов, созданных вручную</small>
            </div>
            
            <!-- Кнопки -->
            <div style="display: flex; gap: 15px; margin-top: 30px;">
                <button type="submit" class="btn btn-blue" style="padding: 12px 30px; cursor: pointer; border: none; border-radius: 8px; font-weight: 600;">
                    Создать проект
                </button>
                <a href="/admin/user-projects" style="background: #6c757d; color: white; padding: 12px 30px; text-decoration: none; border-radius: 8px;">
                    Отмена
                </a>
            </div>
        </form>
        
        <!-- Подсказка -->
        <div style="margin-top: 30px; padding: 15px; background: #f0f7ff; border-radius: 8px; border-left: 4px solid var(--primary-blue);">
            <strong style="color: var(--primary-blue);">Как создать проект из заявки?</strong>
            <p style="margin-top: 8px; color: #555; font-size: 0.85rem;">
                Заявки на услуги, отправленные клиентами, можно одобрить прямо из <a href="/admin/service-orders" style="color: var(--primary-blue);">раздела заявок</a>.
                При одобрении проект создастся автоматически.
            </p>
        </div>
        
    </section>
</main>

<script>
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; margin-bottom: 50px;">
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 15px;">
            <a href="/admin/user-projects" style="background: #6c757d; color: white; padding: 8px 16px; border-radius: 6px; text-decoration: none; font-size: 0.85rem;">
                ← Назад к проектам
            </a>
            <h1 style="margin: 0; font-size: 1.6rem;"><%= project.title %></h1>
        </div>
        <form action="/admin/user-projects/<%= project.id %>/delete" method="POST" onsubmit="return confirm('Вы уверены? Проект и все файлы будут удалены безвозвратно.')" style="display: inline;">
            <button type="submit" style="background: #dc3545; color: white; border: none; padding: 8px 20px; border-radius: 6px; cursor: pointer; font-size: 0.85rem;">
                Удалить проект
            </button>
        </form>
    </div>
    
    <% if (success) { %>
        <div style="background: #d4edda; color: #155724; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
            <%= success %>
        </div>
    <% } %>
    
    <% if (error) { %>
        <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
            <%= error %>
        </div>
    <% } %>
    
    <!-- Основная информация о проекте -->
    <div style="background: white; border-radius: 12px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 30px; overflow: hidden;">
        <div style="background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%); padding: 20px 30px; border-bottom: 1px solid #d0e3ff;">
            <h3 style="margin: 0; color: var(--primary-blue); display: flex; align-items: center; gap: 10px;">
                <i data-lucide="info"></i> Информация о проекте
            </h3>
        </div>
        <div style="padding: 25px 30px;">
            <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 25px;">
                <div>
                    <div style="font-size: 0.75rem; color: #888; text-transform: uppercase;">Клиент</div>
                    <div style="font-size: 1rem; font-weight: 600; margin-top: 5px;"><%= project.user_name || 'Не указан' %></div>
                    <div style="font-size: 0.85rem; color: #666;"><%= project.user_email || '' %></div>
                    <div style="font-size: 0.85rem; color: #666;"><%= project.user_phone || '' %></div>
                </div>
                <div>
                    <div style="font-size: 0.75rem; color: #888; text-transform: uppercase;">Услуга</div>
                    <div style="font-size: 1rem; margin-top: 5px;"><%= project.service_title || '—' %></div>
                </div>
                <div>
                    <div style="font-size: 0.75rem; color: #888; text-transform: uppercase;">Дата создания</div>
                    <div style="font-size: 1rem; margin-top: 5px;"><%= new Date(project.created_at).toLocaleDateString('ru-RU') %></div>
                </div>
            </div>
            
            <div style="margin-bottom: 20px;">
                <div style="font-size: 0.75rem; color: #888; text-transform: uppercase;">Адрес объекта</div>
                <div style="font-size: 1rem; margin-top: 5px;"><%= project.address || 'Не указан' %></div>
            </div>
            
            <!-- Редактирование названия и адреса -->
            <form action="/admin/user-projects/<%= project.id %>/update" method="POST" style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 15px;">
                    <div>
                        <label style="font-size: 0.8rem; color: #666;">Название проекта</label>
                        <input type="text" name="title" value="<%= project.title %>" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 6px; margin-top: 5px;">
                    </div>
                    <div>
                        <label style="font-size: 0.8rem; color: #666;">ID услуги (необязательно)</label>
                        <input type="text" name="service_id" value="<%= project.service_id || '' %>" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 6px; margin-top: 5px;">
                    </div>
                </div>
                <div style="margin-bottom: 15px;">
                    <label style="font-size: 0.8rem; color: #666;">Адрес объекта</label>
                    <input type="text" name="address" value="<%= project.address || '' %>" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 6px; margin-top: 5px;">
                </div>
                <button type="submit" class="btn btn-blue" style="padding: 6px 20px; font-size: 0.8rem;">Обновить данные</button>
            </form>
        </div>
    </div>
    
    <!-- Статус проекта -->
    <div style="background: white; border-radius: 12px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 30px; overflow: hidden;">
        <div style="background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%); padding: 20px 30px; border-bottom: 1px solid #d0e3ff;">
            <h3 style="margin: 0; color: var(--primary-blue); display: flex; align-items: center; gap: 10px;">
                <i data-lucide="bar-chart-2"></i> Статус проекта
            </h3>
        </div>
        <div style="padding: 25px 30px;">
            <form action="/admin/user-projects/<%= project.id %>/status" method="POST" style="display: flex; gap: 20px; align-items: flex-end;">
                <div style="flex: 1;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 500;">Текущий статус</label>
                    <select name="status" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 6px;">
                        <% statuses.forEach(s => { %>
                            <option value="<%= s.value %>" <%= project.status === s.value ? 'selected' : '' %>><%= s.label %></option>
                        <% }) %>
                    </select>
                </div>
                <button type="submit" class="btn btn-blue" style="padding: 10px 25px;">Изменить статус</button>
            </form>
            
            <!-- Визуальный прогресс-бар -->
            <div style="margin-top: 25px;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="font-size: 0.75rem; color: #666;">Прогресс выполнения</span>
                    <span style="font-size: 0.75rem; color: var(--primary-blue); font-weight: 600;">
                        <% 
                            const statusProgress = {
                                'awaiting_approval': 0,
                                'approved': 10,
                                'design': 25,
                                'supply': 45,
                                'installation': 70,
                                'commissioning': 85,
                                'completed': 100
                            };
                            const progress = statusProgress[project.status] || 0;
                        %>
                        <%= progress %>% завершено
                    </span>
                </div>
                <div style="background: #eee; border-radius: 10px; height: 8px; overflow: hidden;">
                    <div style="background: var(--primary-blue); width: <%= progress %>%; height: 100%; border-radius: 10px;"></div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Чат по проекту -->
    <div style="background: white; border-radius: 12px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 30px; overflow: hidden;">
        <div style="background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%); padding: 20px 30px; border-bottom: 1px solid #d0e3ff;">
            <h3 style="margin: 0; color: var(--primary-blue); display: flex; align-items: center; gap: 10px;">
                <i data-lucide="message-circle"></i> Переписка по проекту
            </h3>
        </div>
        <div style="padding: 25px 30px;">
            <!-- История сообщений -->
            <div id="chatMessages" style="max-height: 400px; overflow-y: auto; margin-bottom: 20px; padding: 10px; background: #fafafa; border-radius: 10px;">
                <% if (messages && messages.length > 0) { %>
                    <% messages.forEach(msg => { %>
                        <div style="margin-bottom: 15px; text-align: <%= msg.is_admin ? 'right' : 'left' %>;">
                            <div style="display: inline-block; max-width: 80%; background: <%= msg.is_admin ? 'var(--primary-blue)' : '#e9ecef' %>; color: <%= msg.is_admin ? 'white' : '#333' %>; padding: 10px 15px; border-radius: 15px; text-align left;">
                                <div style="font-size: 0.8rem; font-weight: bold;"><%= msg.is_admin ? 'Администратор' : msg.user_name || 'Клиент' %></div>
                                <div style="margin-top: 5px; font-size: 0.9rem;"><%= msg.message %></div>
                                <div style="font-size: 0.65rem; margin-top: 5px; opacity: 0.7;"><%= new Date(msg.created_at).toLocaleString('ru-RU') %></div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div style="text-align: center; color: #999; padding: 30px;">
                        Сообщений пока нет. Напишите первое сообщение клиенту.
                    </div>
                <% } %>
            </div>
            
            <!-- Форма отправки сообщения -->
            <form action="/admin/user-projects/<%= project.id %>/message" method="POST">
                <textarea name="message" rows="3" placeholder="Введите сообщение для клиента..." style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; resize: vertical; font-family: 'CascadiaCode', monospace; margin-bottom: 10px;" required></textarea>
                <button type="submit" class="btn btn-blue" style="padding: 10px 25px;">Отправить сообщение</button>
            </form>
        </div>
    </div>
    
    <!-- Галерея фото -->
    <div style="background: white; border-radius: 12px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 30px; overflow: hidden;">
        <div style="background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%); padding: 20px 30px; border-bottom: 1px solid #d0e3ff;">
            <h3 style="margin: 0; color: var(--primary-blue); display: flex; align-items: center; gap: 10px;">
                <i data-lucide="image"></i> Фото выполненных работ
            </h3>
        </div>
        <div style="padding: 25px 30px;">
            <!-- Форма загрузки фото -->
            <form action="/admin/user-projects/<%= project.id %>/photo" method="POST" enctype="multipart/form-data" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #eee;">
                <div style="display: flex; gap: 15px; align-items: flex-end;">
                    <div style="flex: 1;">
                        <label style="display: block; margin-bottom: 5px; font-size: 0.8rem;">Фото</label>
                        <input type="file" name="photo" accept="image/jpeg,image/png,image/jpg" required style="width: 100%; padding: 8px;">
                    </div>
                    <div style="flex: 1;">
                        <label style="display: block; margin-bottom: 5px; font-size: 0.8rem;">Описание (необязательно)</label>
                        <input type="text" name="description" placeholder="Например: Монтаж воздуховодов" style="width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 6px;">
                    </div>
                    <button type="submit" class="btn btn-blue" style="padding: 8px 20px;">Загрузить</button>
                </div>
            </form>
            
            <!-- Список фото -->
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px;">
                <% if (photos && photos.length > 0) { %>
                    <% photos.forEach(photo => { %>
                        <div class="photo-card" style="border: 1px solid #eee; border-radius: 8px; overflow: hidden; position: relative;">
                            <img src="/<%= photo.image_url %>" alt="<%= photo.description || 'Фото работ' %>" style="width: 100%; height: 150px; object-fit: cover; cursor: pointer;" onclick="window.open('/<%= photo.image_url %>', '_blank')">
                            <div style="padding: 8px; font-size: 0.75rem; background: #fafafa;">
                                <div style="color: #666; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= photo.description || 'Без описания' %></div>
                                <div style="font-size: 0.65rem; color: #999;"><%= new Date(photo.created_at).toLocaleDateString('ru-RU') %></div>
                                <button onclick="deletePhoto(<%= photo.id %>)" style="position: absolute; top: 5px; right: 5px; background: #dc3545; color: white; border: none; border-radius: 4px; width: 24px; height: 24px; cursor: pointer; font-size: 12px;">×</button>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div style="text-align: center; color: #999; padding: 30px; grid-column: 1 / -1;">
                        Нет загруженных фото
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    
    <!-- Документы -->
    <div style="background: white; border-radius: 12px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); margin-bottom: 30px; overflow: hidden;">
        <div style="background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%); padding: 20px 30px; border-bottom: 1px solid #d0e3ff;">
            <h3 style="margin: 0; color: var(--primary-blue); display: flex; align-items: center; gap: 10px;">
                <i data-lucide="file-text"></i> Документы по проекту
            </h3>
        </div>
        <div style="padding: 25px 30px;">
            <!-- Форма загрузки документа -->
            <form action="/admin/user-projects/<%= project.id %>/document" method="POST" enctype="multipart/form-data" style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #eee;">
                <div style="display: flex; gap: 15px; align-items: flex-end;">
                    <div>
                        <label style="display: block; margin-bottom: 5px; font-size: 0.8rem;">Название документа</label>
                        <input type="text" name="title" placeholder="Договор, смета и т.д." style="width: 250px; padding: 8px; border: 1px solid #ddd; border-radius: 6px;">
                    </div>
                    <div style="flex: 1;">
                        <label style="display: block; margin-bottom: 5px; font-size: 0.8rem;">Файл</label>
                        <input type="file" name="document" required style="width: 100%; padding: 8px;">
                    </div>
                    <button type="submit" class="btn btn-blue" style="padding: 8px 20px;">Загрузить</button>
                </div>
            </form>
            
            <!-- Список документов -->
            <div style="display: flex; flex-direction: column; gap: 10px;">
                <% if (documents && documents.length > 0) { %>
                    <% documents.forEach(doc => { %>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px; background: #f8f9fa; border-radius: 8px;">
                            <div>
                                <i data-lucide="file" style="width: 20px; height: 20px; color: var(--primary-blue); vertical-align: middle;"></i>
                                <span style="margin-left: 10px;"><%= doc.title %></span>
                                <span style="margin-left: 15px; font-size: 0.7rem; color: #888;">
                                    <% if (doc.file_size) { %>
                                        <%= (doc.file_size / 1024).toFixed(1) %> КБ
                                    <% } %>
                                </span>
                            </div>
                            <div>
                                <a href="/<%= doc.file_url %>" download style="background: #28a745; color: white; padding: 4px 12px; border-radius: 5px; text-decoration: none; font-size: 0.75rem; margin-right: 8px;">Скачать</a>
                                <button onclick="deleteDocument(<%= doc.id %>)" style="background: #dc3545; color: white; border: none; padding: 4px 12px; border-radius: 5px; cursor: pointer; font-size: 0.75rem;">Удалить</button>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div style="text-align: center; color: #999; padding: 30px;">
                        Нет загруженных документов
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</main>

<script>
    // Прокрутка чата вниз
    const chatContainer = document.getElementById('chatMessages');
    if (chatContainer) {
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }
    
    // Удаление фото
    async function deletePhoto(photoId) {
        if (confirm('Удалить это фото?')) {
            try {
                const response = await fetch(`/admin/user-projects/photo/${photoId}/delete`, {
                    method: 'POST'
                });
                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Ошибка при удалении');
                }
            } catch (err) {
                alert('Ошибка соединения');
            }
        }
    }
    
    // Удаление документа
    async function deleteDocument(docId) {
        if (confirm('Удалить этот документ?')) {
            try {
                const response = await fetch(`/admin/user-projects/document/${docId}/delete`, {
                    method: 'POST'
                });
                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Ошибка при удалении');
                }
            } catch (err) {
                alert('Ошибка соединения');
            }
        }
    }
    
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>

<%- include('../partials/footer') %>
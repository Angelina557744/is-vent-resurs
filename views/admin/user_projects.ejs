<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px; margin-bottom: 50px;">
    
<%- include('../partials/_admin_sidebar') %>

    <section style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h2 style="margin: 0; display: flex; align-items: center; gap: 12px;">
                <i data-lucide="folder-kanban" style="color: var(--primary-blue);"></i> Проекты клиентов
            </h2>
            <a href="/admin/user-projects/create" class="btn btn-blue" style="padding: 8px 20px; text-decoration: none;">
                + Создать проект
            </a>
        </div>
        
        <% if (success) { %>
            <div style="background: #d4edda; color: #155724; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
                <%= success %>
            </div>
        <% } %>
        
        <% if (error) { %>
            <div style="background: #f8d7da; color: #721c24; padding: 12px; border-radius: 6px; margin-bottom: 20px;">
                <%= error %>
            </div>
        <% } %>
        
        <!-- Фильтр по статусам -->
        <div style="margin-bottom: 25px; display: flex; gap: 10px; flex-wrap: wrap;">
            <button class="status-filter active" data-status="all" style="background: var(--primary-blue); color: white; border: none; padding: 6px 16px; border-radius: 20px; cursor: pointer;">Все</button>
            <button class="status-filter" data-status="awaiting_approval" style="background: #f5f5f5; color: #666; border: 1px solid #ddd; padding: 6px 16px; border-radius: 20px; cursor: pointer;">Ожидание одобрения</button>
            <button class="status-filter" data-status="approved" style="background: #e3f2fd; color: #0277bd; border: 1px solid #0277bd; padding: 6px 16px; border-radius: 20px; cursor: pointer;">Одобрено</button>
            <button class="status-filter" data-status="design" style="background: #e6f4ff; color: #0277bd; border: 1px solid #0277bd; padding: 6px 16px; border-radius: 20px; cursor: pointer;">Проектирование</button>
            <button class="status-filter" data-status="supply" style="background: #fff3e0; color: #f57c00; border: 1px solid #f57c00; padding: 6px 16px; border-radius: 20px; cursor: pointer;">Поставка</button>
            <button class="status-filter" data-status="installation" style="background: #fce4ec; color: #c62828; border: 1px solid #c62828; padding: 6px 16px; border-radius: 20px; cursor: pointer;">Монтаж</button>
            <button class="status-filter" data-status="commissioning" style="background: #e8eaf6; color: #3949ab; border: 1px solid #3949ab; padding: 6px 16px; border-radius: 20px; cursor: pointer;">Пусконаладка</button>
            <button class="status-filter" data-status="completed" style="background: #e8f5e9; color: #2e7d32; border: 1px solid #2e7d32; padding: 6px 16px; border-radius: 20px; cursor: pointer;">Завершены</button>
        </div>
        
        <!-- Статистика по статусам -->
        <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 1px solid #eee;">
            <span style="font-size: 0.85rem; color: #666;">Всего проектов: <strong><%= projects.length %></strong></span>
            <% if (stats.awaiting_approval) { %>
                <span style="font-size: 0.85rem; color: #666;">Ожидают: <strong><%= stats.awaiting_approval %></strong></span>
            <% } %>
            <% if (stats.completed) { %>
                <span style="font-size: 0.85rem; color: #666;">Завершено: <strong><%= stats.completed %></strong></span>
            <% } %>
        </div>
        
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #eee;">
                        <th style="padding: 12px; text-align: left;">ID</th>
                        <th style="padding: 12px; text-align: left;">Проект / Клиент</th>
                        <th style="padding: 12px; text-align: left;">Услуга</th>
                        <th style="padding: 12px; text-align: left;">Статус</th>
                        <th style="padding: 12px; text-align: left;">Дата создания</th>
                        <th style="padding: 12px; text-align: center;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (projects && projects.length > 0) { %>
                        <% projects.forEach(project => { 
                            let statusLabel = '';
                            let statusColor = '';
                            
                            switch(project.status) {
                                case 'awaiting_approval': statusLabel = 'Ожидание одобрения'; statusColor = '#f5f5f5'; break;
                                case 'approved': statusLabel = 'Одобрено'; statusColor = '#e3f2fd'; break;
                                case 'design': statusLabel = 'Проектирование'; statusColor = '#e6f4ff'; break;
                                case 'supply': statusLabel = 'Поставка'; statusColor = '#fff3e0'; break;
                                case 'installation': statusLabel = 'Монтаж'; statusColor = '#fce4ec'; break;
                                case 'commissioning': statusLabel = 'Пусконаладка'; statusColor = '#e8eaf6'; break;
                                case 'completed': statusLabel = 'Завершен'; statusColor = '#e8f5e9'; break;
                                default: statusLabel = project.status; statusColor = '#f5f5f5';
                            }
                        %>
                            <tr class="project-row" data-status="<%= project.status %>" style="border-bottom: 1px solid #eee;">
                                <td style="padding: 12px;">#<%= project.id %></td>
                                <td style="padding: 12px;">
                                    <strong><%= project.title %></strong><br>
                                    <small style="color: #888;"><%= project.user_name || 'Клиент не найден' %></small><br>
                                    <small style="color: #aaa;"><%= project.user_email || '' %></small>
                                </td>
                                <td style="padding: 12px;">
                                    <%= project.service_title || '—' %>
                                </td>
                                <td style="padding: 12px;">
                                    <span style="display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 500; background: <%= statusColor %>;">
                                        <%= statusLabel %>
                                    </span>
                                </td>
                                <td style="padding: 12px; color: #888; font-size: 0.85rem;">
                                    <%= new Date(project.created_at).toLocaleDateString('ru-RU') %>
                                </td>
                                <td style="padding: 12px; text-align: center;">
                                    <a href="/admin/user-projects/<%= project.id %>" style="background: var(--primary-blue); color: white; padding: 5px 12px; border-radius: 5px; text-decoration: none; font-size: 0.75rem;">Открыть</a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="padding: 50px; text-align: center; color: #999;">
                                <i data-lucide="folder-kanban" size="48" style="color: #ddd; margin-bottom: 10px;"></i>
                                <p>Нет созданных проектов</p>
                                <a href="/admin/user-projects/create" class="btn btn-blue" style="padding: 8px 20px; text-decoration: none; display: inline-block; margin-top: 10px;">Создать первый проект</a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </section>
</main>

<script>
    // Фильтрация проектов по статусу
    const filterBtns = document.querySelectorAll('.status-filter');
    const projectRows = document.querySelectorAll('.project-row');
    
    filterBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const status = this.dataset.status;
            
            filterBtns.forEach(b => {
                b.classList.remove('active');
                b.style.background = '';
                b.style.color = '';
            });
            
            this.classList.add('active');
            if (status === 'all') {
                this.style.background = 'var(--primary-blue)';
                this.style.color = 'white';
            } else {
                this.style.background = '#f0f7ff';
                this.style.color = 'var(--primary-blue)';
            }
            
            projectRows.forEach(row => {
                if (status === 'all' || row.dataset.status === status) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    });
    
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>

<style>
    .btn-blue {
        background: var(--primary-blue);
        color: white;
        border: none;
        cursor: pointer;
        border-radius: 8px;
        transition: 0.3s;
    }
    .btn-blue:hover {
        background: var(--dark-blue);
    }
    .status-filter.active {
        border: none !important;
    }
</style>

<%- include('../partials/footer') %>
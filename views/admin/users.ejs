<%- include('../partials/header') %>

<main class="container" style="margin-top: 40px; display: grid; grid-template-columns: 250px 1fr; gap: 30px;">
   
       <%- include('../partials/_admin_sidebar') %>

    <section style="background: white; padding: 30px; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.05);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2>Пользователи</h2>
        </div>
        <hr style="margin-bottom: 20px;">

        <% if (success) { %>
            <div style="background: #d4edda; color: #155724; padding: 10px; border-radius: 6px; margin-bottom: 20px;"><%= success %></div>
        <% } %>
        <% if (error) { %>
            <div style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 6px; margin-bottom: 20px;"><%= error %></div>
        <% } %>

        <!-- Фильтры и поиск -->
        <form method="GET" style="display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: 25px;">
            <input type="text" name="search" placeholder="Поиск по имени, email, телефону" value="<%= search %>" style="flex: 2; padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
            <select name="role" style="padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
    <option value="all" <%= role === 'all' ? 'selected' : '' %>>Все роли</option>
    <option value="user" <%= role === 'user' ? 'selected' : '' %>>Пользователи</option>
    <option value="manager" <%= role === 'manager' ? 'selected' : '' %>>Менеджеры</option>
    <option value="admin" <%= role === 'admin' ? 'selected' : '' %>>Администраторы</option>
</select>
            <input type="hidden" name="sort" value="<%= sort %>">
            <input type="hidden" name="order" value="<%= order %>">
            <button type="submit" class="btn btn-blue" style="padding: 8px 20px;">Применить</button>
            <a href="/admin/users" class="btn" style="padding: 8px 20px; background: #6c757d; color: white; text-decoration: none; border-radius: 5px;">Сбросить</a>
        </form>

        <!-- Таблица пользователей -->
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #eee;">
                        <th style="padding: 12px;"><a href="?search=<%= search %>&role=<%= role %>&sort=id&order=<%= sort === 'id' && order === 'asc' ? 'desc' : 'asc' %>" style="text-decoration: none; color: #333;">ID <%= sort === 'id' ? (order === 'asc' ? '↑' : '↓') : '' %></a></th>
                        <th style="padding: 12px;"><a href="?search=<%= search %>&role=<%= role %>&sort=name&order=<%= sort === 'name' && order === 'asc' ? 'desc' : 'asc' %>" style="text-decoration: none; color: #333;">ФИО <%= sort === 'name' ? (order === 'asc' ? '↑' : '↓') : '' %></a></th>
                        <th style="padding: 12px;">Email</th>
                        <th style="padding: 12px;">Телефон</th>
                        <th style="padding: 12px;">Роль</th>
                        <th style="padding: 12px;">Статус</th>
                        <th style="padding: 12px;"><a href="?search=<%= search %>&role=<%= role %>&sort=date&order=<%= sort === 'date' && order === 'asc' ? 'desc' : 'asc' %>" style="text-decoration: none; color: #333;">Регистрация <%= sort === 'date' ? (order === 'asc' ? '↑' : '↓') : '' %></a></th>
                        <th style="padding: 12px;">Квизы</th>
                        <th style="padding: 12px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 12px;"><%= user.id %></td>
                            <td style="padding: 12px;"><strong><%= user.full_name %></strong><br><small style="color:#888;"><%= user.username %></small></td>
                            <td style="padding: 12px;"><%= user.email %></td>
                            <td style="padding: 12px;"><%= user.phone || '-' %></td>
                           <td style="padding: 12px;">
    <% if (user.role === 'admin') { %>
        <span style="background: #dc3545; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem;">Администратор</span>
    <% } else if (user.role === 'manager') { %>
        <span style="background: #ffa500; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem;">Менеджер</span>
    <% } else { %>
        <span style="background: #28a745; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem;">Пользователь</span>
    <% } %>
</td>
                            <td style="padding: 12px;">
                                <% if (user.is_blocked) { %>
                                    <span style="background: #ffc107; color: #333; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem;">Заблокирован</span>
                                <% } else { %>
                                    <span style="background: #28a745; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem;">Активен</span>
                                <% } %>
                            </td>
                            <td style="padding: 12px;"><%= new Date(user.created_at).toLocaleDateString('ru-RU') %></td>
                            <td style="padding: 12px;"><%= user.quiz_count %></td>
                            <td style="padding: 12px;">
                                <a href="/admin/users/<%= user.id %>/edit" style="background: var(--primary-blue); color: white; padding: 5px 10px; border-radius: 4px; text-decoration: none; font-size: 0.75rem;">Редактировать</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
        <% if (users.length === 0) { %>
            <p style="text-align: center; color: #999; padding: 40px;">Пользователи не найдены</p>
        <% } %>
    </section>
</main>

<%- include('../partials/footer') %>
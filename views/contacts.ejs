<%- include('partials/header') %>

<section class="page-header" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/img/contacts-bg.jpg') center/cover; padding: 80px 0; color: white; text-align: center;">
    <div class="container">
        <h1 style="font-size: 3rem; margin-bottom: 10px;">Контакты</h1>
        <p style="font-size: 1.2rem; opacity: 0.9;">Свяжитесь с нами любым удобным способом</p>
    </div>
</section>

<section style="padding: 60px 0;">
    <div class="container">
        <div style="display: flex; flex-wrap: wrap; gap: 40px; align-items: stretch;">
            
            <div style="flex: 1; min-width: 320px;">
                <div class="contact-item">
                    <h3 style="color: var(--primary-blue); margin-bottom: 5px;">Наш адрес:</h3>
                    <p><%= settings.contact_address %></p>
                    <p style="font-size: 0.9rem; color: #777;"><%= settings.contact_address_note %></p>
                </div>
                <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

                <div class="contact-item">
                    <h3 style="color: var(--primary-blue); margin-bottom: 5px;">Телефоны:</h3>
                    <p><strong><%= settings.contact_phone_main %></strong> (Бухгалтерия, заявки)</p>
                    <p><strong><%= settings.contact_phone_extra %></strong> (Для регионов РФ)</p>
                </div>
                <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

                <div class="contact-item">
                    <h3 style="color: var(--primary-blue); margin-bottom: 5px;">Часы работы:</h3>
                    <p><%= settings.contact_work_hours %></p>
                </div>
                <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;">

                <div class="contact-item">
                    <h3 style="color: var(--primary-blue); margin-bottom: 5px;">Email:</h3>
                    <p><a href="mailto:<%= settings.contact_email %>" style="color: inherit;"><%= settings.contact_email %></a></p>
                </div>
                
                <a href="#feedback" class="btn btn-blue" style="width: 100%; margin-top: 30px; text-align: center; display: block; padding: 15px;">Задать вопрос</a>
            </div>

            <div style="flex: 1; min-width: 320px; min-height: 450px; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                <div id="map" style="width: 100%; height: 100%;"></div>
            </div>

        </div>
    </div>
</section>

<section style="padding: 60px 0; background: #f9f9f9;">
    <div class="container">
        <h2 style="text-align: center; margin-bottom: 40px;">Наш офис и производство</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
            <img src="/img/office-1.jpg" style="width: 100%; height: 250px; object-fit: cover; border-radius: 20px;" alt="Офис">
            <img src="/img/office-2.jpg" style="width: 100%; height: 250px; object-fit: cover; border-radius: 20px;" alt="Офис">
            <img src="/img/office-3.jpg" style="width: 100%; height: 250px; object-fit: cover; border-radius: 20px;" alt="Производство">
            <img src="/img/office-4.jpg" style="width: 100%; height: 250px; object-fit: cover; border-radius: 20px;" alt="Производство">
        </div>
    </div>
</section>

<section id="feedback" style="padding: 100px 0;">
    <div class="container">
        <div style="max-width: 600px; margin: 0 auto; background: white; padding: 40px; border-radius: 20px; box-shadow: 0 15px 50px rgba(0,0,0,0.08);">
            <div style="text-align: center; margin-bottom: 30px;">
                <h2 style="margin-bottom: 10px;">Остались вопросы?</h2>
                <p style="color: #666;">
                    Задайте вопрос и получите ответ на него в своем <strong>личном кабинете</strong>, 
                    либо мы свяжемся с вами для уточнения деталей.
                </p>
            </div>
            
            <form id="contactQuestionForm" style="display: flex; flex-direction: column; gap: 15px;">
                <input type="text" id="q_name" placeholder="Ваше имя" required 
                       value="<%= user ? user.full_name : '' %>"
                       style="padding: 15px; border: 1px solid #ddd; border-radius: 10px;">
                
                <div style="display: flex; gap: 15px;">
                    <input type="tel" id="q_phone" placeholder="Телефон" required 
                           style="flex: 1; padding: 15px; border: 1px solid #ddd; border-radius: 10px;">
                    <input type="email" id="q_email" placeholder="Email" required 
                           value="<%= user ? user.email : '' %>"
                           style="flex: 1; padding: 15px; border: 1px solid #ddd; border-radius: 10px;">
                </div>
                
                <textarea id="q_message" placeholder="Ваш вопрос" rows="4" required 
                          style="padding: 15px; border: 1px solid #ddd; border-radius: 10px; resize: none;"></textarea>
                
                <button type="submit" class="btn btn-blue" style="padding: 15px; font-weight: bold; font-size: 1rem;">
                    Отправить вопрос
                </button>
            </form>
        </div>
    </div>
</section>

<div id="map-data" 
     data-coords="<%= settings.contact_map_coords || '51.815344, 55.152431' %>"
     data-address="<%= settings.contact_address || 'г. Оренбург, ул. Просторная 23/3' %>">
</div>

<script src="https://api-maps.yandex.ru/2.1/?lang=ru_RU" type="text/javascript"></script>
<script src="/js/map.js"></script>

<script>
document.getElementById('contactQuestionForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = {
        name: document.getElementById('q_name').value,
        phone: document.getElementById('q_phone').value,
        email: document.getElementById('q_email').value,
        message: document.getElementById('q_message').value
    };

    try {
        const res = await fetch('/api/contact-message', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(data)
        });

        const result = await res.json();
        if (result.success) {
            alert('Вопрос отправлен! Ответ появится в вашем личном кабинете.');
            e.target.reset();
        } else {
            alert('Ошибка при отправке сообщения.');
        }
    } catch (err) {
        console.error('Error:', err);
        alert('Не удалось отправить сообщение.');
    }
});
</script>

<!-- Модальное уведомление -->
<div id="notificationModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center;">
    <div style="background: white; max-width: 400px; width: 90%; padding: 30px; border-radius: 16px; text-align: center; box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
        <div id="notificationIcon" style="width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px auto;">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </div>
        <h3 id="notificationTitle" style="margin: 0 0 10px 0; font-size: 1.3rem;">Заголовок</h3>
        <p id="notificationMessage" style="color: #666; margin-bottom: 20px; line-height: 1.5;">Текст уведомления</p>
        <button onclick="closeNotification()" style="background: #007bff; color: white; border: none; padding: 10px 30px; border-radius: 30px; cursor: pointer; font-size: 0.9rem; font-weight: 600;">Закрыть</button>
    </div>
</div>

<script>
    function showNotification(type, title, message) {
        const modal = document.getElementById('notificationModal');
        const iconDiv = document.getElementById('notificationIcon');
        const titleEl = document.getElementById('notificationTitle');
        const messageEl = document.getElementById('notificationMessage');
        
        if (type === 'success') {
            iconDiv.style.background = '#28a745';
            titleEl.style.color = '#28a745';
        } else if (type === 'error') {
            iconDiv.style.background = '#dc3545';
            titleEl.style.color = '#dc3545';
        } else {
            iconDiv.style.background = '#007bff';
            titleEl.style.color = '#007bff';
        }
        
        titleEl.textContent = title;
        messageEl.textContent = message;
        modal.style.display = 'flex';
    }
    
    function closeNotification() {
        document.getElementById('notificationModal').style.display = 'none';
    }
    
    // Обновленная отправка формы
    document.getElementById('contactQuestionForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const data = {
            name: document.getElementById('q_name').value,
            phone: document.getElementById('q_phone').value,
            email: document.getElementById('q_email').value,
            message: document.getElementById('q_message').value
        };
        
        try {
            const res = await fetch('/api/contact-message', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            });
            
            const result = await res.json();
            
            if (result.success) {
                showNotification('success', 'Сообщение отправлено', 'Ваш вопрос успешно отправлен. Ответ появится в личном кабинете.');
                e.target.reset();
            } else {
                showNotification('error', 'Ошибка', result.error || 'Не удалось отправить сообщение. Попробуйте позже.');
            }
        } catch (err) {
            console.error('Error:', err);
            showNotification('error', 'Ошибка', 'Не удалось отправить сообщение. Проверьте соединение.');
        }
    });
</script>

<%- include('partials/footer') %>
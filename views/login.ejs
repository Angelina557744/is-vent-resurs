
<% if (typeof error !== 'undefined') { %>
    <div style="background: #ffeded; color: #d93025; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;">
        <%= error %>
    </div>
<% } %>

<%- include('partials/header') %>

<main class="container" style="margin-top: 50px; display: flex; justify-content: center;">
    <div class="auth-card animate__animated animate__fadeIn">
        <h2>Вход в кабинет</h2>
        <form action="/login" method="POST">
<div class="form-group">
    <label>Логин</label>
    <input type="text" name="login" required> </div>
            <div class="form-group">
                <label>Пароль</label>
                <input type="password" name="password" required>
            </div>
            <button type="submit" class="btn btn-blue" style="width: 100%; margin-top: 20px;">Войти</button>
        </form>
        <p style="margin-top: 15px; text-align: center;">
            Нет аккаунта? <a href="/register" style="color: var(--primary-blue);">Регистрация</a>
        </p>
    </div>
</main>

<%- include('partials/footer') %>
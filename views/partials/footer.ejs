        <div class="container">
            <div class="footer-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; border-bottom: 1px solid #333; padding-bottom: 40px;">
                <div class="footer-info">
                    <div class="logo" style="font-weight: bold; font-size: 24px; color: white; margin-bottom: 15px;">
                        Вент<span style="color: var(--primary-blue);">Ресурс</span>
                    </div>
                    <p style="color: #888; font-weight: 300;">2007-2026 &copy; ООО "Компания ВентРесурс"</p>
                    <p style="color: #888; font-weight: 300;">Промышленная вентиляция, отопление, кондиционирование.</p>
                </div>
                <div class="footer-contacts">
                    <h4 style="margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px;">Контакты</h4>
                    <div style="display: flex; flex-direction: column; gap: 10px; color: #ccc; font-weight: 200; font-size: 0.9rem;">
                        <span><i data-lucide="map-pin" size="16" style="margin-right: 10px; color: var(--primary-blue);"></i> 460052, Россия, г. Оренбург, ул. Просторная 23/3</span>
                        <span><i data-lucide="phone" size="16" style="margin-right: 10px; color: var(--primary-blue);"></i> +7 (3532) 43-99-99</span>
                        <span><i data-lucide="mail" size="16" style="margin-right: 10px; color: var(--primary-blue);"></i> v-resurs@mail.ru</span>
                    </div>

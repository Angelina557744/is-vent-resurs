        cursor: pointer !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        font-family: 'CascadiaCode', monospace !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 8px !important;
        transition: all 0.3s ease !important;
    }
    
    .profile-save-button:hover {
        background: linear-gradient(135deg, #1e7e34 0%, #166b2c 100%) !important;
        transform: translateY(-2px) !important;
        box-shadow: 0 4px 12px rgba(40,167,69,0.3) !important;
    }
    
    /* Кнопка Отмена */
    .profile-cancel-button {
        flex: 1 !important;
        padding: 12px 20px !important;
        background: #ffffff !important;
        color: #6c757d !important;
        border: 2px solid #dee2e6 !important;
        border-radius: 50px !important;
        cursor: pointer !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        font-family: 'CascadiaCode', monospace !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 8px !important;
        transition: all 0.3s ease !important;
    }
    
    .profile-cancel-button:hover {
        background: #f8f9fa !important;
        border-color: #adb5bd !important;
        color: #495057 !important;
        transform: translateY(-2px) !important;
    }
    
    /* Контейнер для кнопок */
    #profile-edit-mode > form > div:nth-child(2) {
        display: flex !important;
        gap: 12px !important;
        margin-top: 20px !important;
    }
    
    /* Иконки в кнопках */
    .profile-save-icon,
    .profile-cancel-icon {
        width: 16px !important;
        height: 16px !important;
    }
    
    /* Анимация появления */
    #profile-edit-mode {
        animation: fadeInUp 0.4s ease;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Сообщение */
    #profile-message {
        margin-top: 15px;
        padding: 10px;
        border-radius: 10px;
        text-align: center;
        font-size: 13px;
        font-weight: 500;
    }

}</style>


<script>
    // Инициализация иконок Lucide
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
</script>

<script>
// Переключение на режим редактирования
function enableEditMode() {
    document.getElementById('profile-view-mode').style.display = 'none';
    document.getElementById('profile-edit-mode').style.display = 'block';
    lucide.createIcons();
}

// Отмена редактирования
function disableEditMode() {
    document.getElementById('profile-view-mode').style.display = 'block';
    document.getElementById('profile-edit-mode').style.display = 'none';
    document.getElementById('profile-message').innerHTML = '';
    lucide.createIcons();
}
async function saveProfile(event) {
    event.preventDefault();
    
    const form = document.getElementById('profile-edit-form');
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    const messageDiv = document.getElementById('profile-message');
    messageDiv.innerHTML = '<span style="color: #007bff;">Сохранение...</span>';
    
    try {
        const response = await fetch('/api/profile/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            messageDiv.innerHTML = '<span style="color: #28a745;">✅ ' + result.message + '</span>';
            // Обновляем отображаемые данные на странице
            document.getElementById('view-email').innerText = data.email;
            document.getElementById('view-phone').innerText = data.phone || 'Не указан';
            // Обновляем значения в форме редактирования
            document.querySelector('input[name="email"]').value = data.email;
            document.querySelector('input[name="phone"]').value = data.phone || '';
            // Возвращаемся в режим просмотра через 1.5 секунды
            setTimeout(() => {
                disableEditMode();
            }, 1500);
        } else {
            messageDiv.innerHTML = '<span style="color: #dc3545;">❌ ' + result.error + '</span>';
        }
    } catch (err) {
        messageDiv.innerHTML = '<span style="color: #dc3545;">❌ Ошибка соединения</span>';
    }
}
</script>


<%- include('partials/header') %>

<div class="container" style="margin-top: 50px; max-width: 800px; margin-bottom: 50px;">
    <div id="quiz-container" style="background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border: 1px solid #e0e0e0;">
        
        <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="color: var(--primary-blue); margin-bottom: 10px;">Инженерный калькулятор</h2>
            <p style="color: #666; font-size: 0.9rem;">Предварительный расчет стоимости</p>
        </div>

        <div style="margin-bottom: 30px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 0.85rem; color: #777;">
                <span id="progress-text">Шаг 1 из 5</span>
                <span id="step-title">Отрасль объекта</span>
            </div>
            <div style="width: 100%; background: #eee; height: 6px; border-radius: 3px;">
                <div id="progress" style="width: 20%; background: var(--primary-blue); height: 100%; border-radius: 3px; transition: 0.4s ease;"></div>
            </div>
        </div>

        <form id="quiz-form">
            <div class="step" id="step1">
                <h3 style="margin-bottom: 20px;"><i data-lucide="building-2" style="vertical-align: middle; margin-right: 10px;"></i>1. Выберите сферу деятельности:</h3>
                <div class="quiz-grid">
                    <label class="quiz-option-card">
                        <input type="radio" name="industry" value="Промышленность" checked>
                        <div class="option-content">
                            <strong>Промышленность</strong>
                            <span>Заводы, цеха, склады</span>
                        </div>
                    </label>
                    <label class="quiz-option-card">
                        <input type="radio" name="industry" value="Пищевая">
                        <div class="option-content">
                            <strong>Пищевая / АПК</strong>
                            <span>Молокозаводы, овощехранилища</span>
                        </div>
                    </label>
                    <label class="quiz-option-card">
                        <input type="radio" name="industry" value="Бизнес">
                        <div class="option-content">
                            <strong>Коммерция</strong>
                            <span>Офисы, ТРЦ, Рестораны</span>
                        </div>
                    </label>
                    <label class="quiz-option-card">
                        <input type="radio" name="industry" value="Медицина">
                        <div class="option-content">
                            <strong>Медицина</strong>
                            <span>Больницы, лаборатории</span>
                        </div>
                    </label>
                </div>
            </div>

            <div class="step" id="step2" style="display:none;">
                <h3 style="margin-bottom: 20px;"><i data-lucide="settings-2" style="vertical-align: middle; margin-right: 10px;"></i>2. Тип инженерной системы:</h3>
                <div class="quiz-stack">
                    <label class="quiz-option-card">
                        <input type="radio" name="building_type" value="Вентиляция" checked>
                        <div class="option-content"><strong>Приточно-вытяжная вентиляция</strong></div>
                    </label>
                    <label class="quiz-option-card">
                        <input type="radio" name="building_type" value="Холодоснабжение">
                        <div class="option-content"><strong>Холодоснабжение (Чиллеры / VRF)</strong></div>
                    </label>
                    <label class="quiz-option-card">
                        <input type="radio" name="building_type" value="Отопление">
                        <div class="option-content"><strong>Воздушное отопление (Руфтопы)</strong></div>
                    </label>
                </div>
            </div>

            <div class="step" id="step3" style="display:none;">
                <h3 style="margin-bottom: 20px;"><i data-lucide="move-3d" style="vertical-align: middle; margin-right: 10px;"></i>3. Размеры помещения:</h3>
                <div class="input-group">
                    <div class="field">
                        <label>Площадь объекта (м²):</label>
                        <input type="number" name="area" value="100" min="1" class="quiz-input">
                    </div>
                    <div class="field">
                        <label>Высота потолков (м):</label>
                        <input type="number" name="ceiling_height" value="3" min="2" step="0.1" class="quiz-input">
                    </div>
                </div>
            </div>

            <div class="step" id="step4" style="display:none;">
                <h3 style="margin-bottom: 20px;"><i data-lucide="users-2" style="vertical-align: middle; margin-right: 10px;"></i>4. Дополнительные параметры:</h3>
                <div class="field" style="margin-bottom: 20px;">
                    <label>Количество людей на объекте:</label>
                    <input type="number" name="people_count" value="5" min="0" class="quiz-input">
                </div>
                <label class="checkbox-card">
                    <input type="checkbox" name="automation" value="yes">
                    <span>Нужна автоматизация и КИПиА (диспетчеризация)</span>
                </label>
            </div>

            <div class="step" id="step5" style="display:none;">
                <h3 style="margin-bottom: 20px;"><i data-lucide="wallet" style="vertical-align: middle; margin-right: 10px;"></i>5. Класс оборудования:</h3>
                <div class="quiz-stack">
                    <label class="quiz-option-card">
                        <input type="radio" name="budget_range" value="Эконом" checked>
                        <div class="option-content"><strong>Эконом</strong><span>Отечественное оборудование</span></div>
                    </label>
                    <label class="quiz-option-card">
                        <input type="radio" name="budget_range" value="Стандарт">
                        <div class="option-content"><strong>Стандарт</strong><span>Оптимальное качество</span></div>
                    </label>
                    <label class="quiz-option-card">
                        <input type="radio" name="budget_range" value="Премиум">
                        <div class="option-content"><strong>Премиум</strong><span>Мировые бренды (Daikin, Systemair)</span></div>
                    </label>
                </div>
            </div>

            <div style="margin-top: 40px; display: flex; justify-content: space-between;">
                <button type="button" id="prevBtn" class="btn-quiz-sec" style="visibility: hidden;">Назад</button>
                <button type="button" id="nextBtn" class="btn-quiz-pri">Далее</button>
            </div>
        </form>

        <div id="quiz-result" style="display: none;"></div>
    </div>
</div>

<style>
    .quiz-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
    .quiz-stack { display: flex; flex-direction: column; gap: 10px; }
    .quiz-option-card {
        border: 2px solid #f0f0f0; padding: 15px; border-radius: 12px; cursor: pointer;
        display: flex; align-items: flex-start; gap: 12px; transition: 0.2s;
    }
    .quiz-option-card:hover { border-color: var(--primary-blue); background: #f9fbff; }
    .quiz-option-card input { margin-top: 5px; }
    .option-content strong { display: block; color: #333; }
    .option-content span { font-size: 0.8rem; color: #888; }
    
    .input-group { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .quiz-input { width: 100%; padding: 12px; border: 2px solid #eee; border-radius: 8px; margin-top: 5px; }
    
    .checkbox-card {
        display: flex; align-items: center; gap: 10px; padding: 15px;
        background: #f8f9fa; border-radius: 10px; cursor: pointer;
    }

    .btn-quiz-pri { background: var(--primary-blue); color: white; border: none; padding: 12px 35px; border-radius: 8px; font-weight: bold; cursor: pointer; }
    .btn-quiz-sec { background: #eee; color: #555; border: none; padding: 12px 35px; border-radius: 8px; cursor: pointer; }

    /* Лоадер */
    .loader {
        border: 4px solid #f3f3f3; border-top: 4px solid var(--primary-blue);
        border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>

<script>
    let currentStep = 1;
    const totalSteps = 5;
    const stepTitles = ["Отрасль", "Система", "Габариты", "Детали", "Бюджет"];

    const nextBtn = document.getElementById('nextBtn');
    const prevBtn = document.getElementById('prevBtn');

    nextBtn.onclick = () => {
        if (currentStep < totalSteps) {
            document.getElementById('step' + currentStep).style.display = 'none';
            currentStep++;
            document.getElementById('step' + currentStep).style.display = 'block';
            updateUI();
        } else {
            calculateAndSave();
        }
    };

    prevBtn.onclick = () => {
        document.getElementById('step' + currentStep).style.display = 'none';
        currentStep--;
        document.getElementById('step' + currentStep).style.display = 'block';
        updateUI();
    };

    function updateUI() {
        document.getElementById('progress').style.width = (currentStep / totalSteps) * 100 + '%';
        document.getElementById('progress-text').innerText = `Шаг ${currentStep} из ${totalSteps}`;
        document.getElementById('step-title').innerText = stepTitles[currentStep-1];
        prevBtn.style.visibility = currentStep === 1 ? 'hidden' : 'visible';
        nextBtn.innerText = currentStep === totalSteps ? 'Рассчитать' : 'Далее';
    }

    async function calculateAndSave() {
    const formData = new FormData(document.getElementById('quiz-form'));
    const data = Object.fromEntries(formData.entries());
    
    let price = data.area * 5000;
    if(data.budget_range === 'Премиум') price *= 1.5;
    if(data.building_type === 'Производство') price *= 1.3;
    data.estimated_price = price;

    const resultBlock = document.getElementById('quiz-result');
    document.getElementById('quiz-form').style.display = 'none';
    document.getElementById('progress').parentElement.style.display = 'none';
    resultBlock.style.display = 'block';
    resultBlock.innerHTML = '<div class="loader"></div><p>ИИ ВентРесурс формирует экспертное мнение...</p>';

    try {
        const response = await fetch('/api/quiz-save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });

        const result = await response.json();
        
        resultBlock.innerHTML = `
            <i data-lucide="check-circle" style="color: #28a745; width: 60px; height: 60px; margin-bottom: 20px;"></i>
            <h2>Расчет готов!</h2>
            <p style="font-size: 2rem; color: #007bff; font-weight: bold;">${price.toLocaleString()} руб.</p>
            <div style="background: #f0f7ff; padding: 15px; border-radius: 10px; margin: 20px 0; text-align: left; border-left: 4px solid #007bff;">
                <strong style="font-size: 0.8rem; color: #007bff;">ИНЖЕНЕРНЫЙ АНАЛИЗ ИИ:</strong>
                <p style="font-style: italic; font-size: 0.95rem; margin-top: 5px;">"${result.recommendation}"</p>
            </div>
            <a href="/profile" class="btn btn-blue">Перейти в профиль</a>
        `;
        if(window.lucide) lucide.createIcons();
    } catch (e) {
        resultBlock.innerHTML = '<p>Ошибка связи с сервером.</p>';
    }
}
</script>

<%- include('partials/footer') %>




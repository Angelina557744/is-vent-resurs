<%- include('partials/header') %>

<div class="container" style="margin-top: 50px; max-width: 700px;">
    <div id="quiz-container" style="background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
        
        <div style="width: 100%; background: #eee; height: 8px; border-radius: 4px; margin-bottom: 30px;">
            <div id="progress" style="width: 20%; background: var(--primary-blue); height: 100%; border-radius: 4px; transition: 0.3s;"></div>
        </div>

        <form id="quiz-form">
            <div class="step" id="step1">
                <h3>1. Выберите тип объекта:</h3>
                <div style="display: grid; gap: 10px; margin-top: 20px;">
                    <label class="quiz-option"><input type="radio" name="building_type" value="Квартира/Дом" required> Частный дом / Квартира</label>
                    <label class="quiz-option"><input type="radio" name="building_type" value="Офис"> Офисное помещение</label>
                    <label class="quiz-option"><input type="radio" name="building_type" value="Магазин/ТЦ"> Магазин / ТЦ</label>
                    <label class="quiz-option"><input type="radio" name="building_type" value="Производство"> Производственный цех</label>
                </div>
            </div>

            <div class="step" id="step2" style="display:none;">
                <h3>2. Укажите площадь помещения (м²):</h3>
                <input type="number" name="area" id="quiz-area" placeholder="Например: 100" style="width: 100%; padding: 15px; margin-top: 20px; border: 1px solid #ddd; border-radius: 10px;">
            </div>

            <div class="step" id="step3" style="display:none;">
                <h3>3. Сколько человек постоянно находится в помещении?</h3>
                <input type="number" name="people_count" id="quiz-people" placeholder="Например: 5" style="width: 100%; padding: 15px; margin-top: 20px; border: 1px solid #ddd; border-radius: 10px;">
            </div>

            <div class="step" id="step4" style="display:none;">
                <h3>4. Какой класс оборудования рассматриваете?</h3>
                <div style="display: grid; gap: 10px; margin-top: 20px;">
                    <label class="quiz-option"><input type="radio" name="budget_range" value="Эконом"> Эконом (Базовое решение)</label>
                    <label class="quiz-option"><input type="radio" name="budget_range" value="Стандарт"> Стандарт (Оптимально)</label>
                    <label class="quiz-option"><input type="radio" name="budget_range" value="Премиум"> Премиум (Энергосбережение)</label>
                </div>
            </div>

            <div style="margin-top: 30px; display: flex; justify-content: space-between;">
                <button type="button" id="prevBtn" class="btn btn-outline" style="display:none;">Назад</button>
                <button type="button" id="nextBtn" class="btn btn-blue">Далее →</button>
            </div>
        </form>

        <div id="quiz-result" style="display:none; text-align: center;">
            <i data-lucide="check-circle" style="color: #28a745; width: 60px; height: 60px; margin-bottom: 20px;"></i>
            <h2>Расчет готов!</h2>
            <p style="font-size: 1.2rem; margin: 20px 0;">Ориентировочная стоимость системы: <br>
                <strong id="final-price" style="font-size: 2rem; color: var(--primary-blue);">0</strong> руб.
            </p>
            <p style="color: #666;">Результаты сохранены в вашем кабинете.</p>
            <a href="/profile" class="btn btn-blue" style="margin-top: 20px;">В личный кабинет</a>
        </div>
    </div>
</div>

<style>
    .quiz-option {
        padding: 15px;
        border: 1px solid #ddd;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.3s;
    }
    .quiz-option:hover { background: #f0f7ff; border-color: var(--primary-blue); }
    .quiz-option input { margin-right: 10px; }
</style>

<script>
    let currentStep = 1;
    const totalSteps = 4;

    const nextBtn = document.getElementById('nextBtn');
    const prevBtn = document.getElementById('prevBtn');
    const progress = document.getElementById('progress');

    nextBtn.onclick = async () => {
        if (currentStep < totalSteps) {
            document.getElementById('step' + currentStep).style.display = 'none';
            currentStep++;
            document.getElementById('step' + currentStep).style.display = 'block';
            updateUI();
        } else {
            calculateAndSave();
        }
    };

    prevBtn.onclick = () => {
        document.getElementById('step' + currentStep).style.display = 'none';
        currentStep--;
        document.getElementById('step' + currentStep).style.display = 'block';
        updateUI();
    };

    function updateUI() {
        progress.style.width = (currentStep / totalSteps) * 100 + '%';
        prevBtn.style.display = currentStep === 1 ? 'none' : 'block';
        nextBtn.innerText = currentStep === totalSteps ? 'Получить расчет' : 'Далее →';
    }

    async function calculateAndSave() {
        const formData = new FormData(document.getElementById('quiz-form'));
        const data = Object.fromEntries(formData.entries());
        
        // Логика примерного расчета (5000р за м2 + набавка за тип)
        let price = data.area * 5000;
        if(data.budget_range === 'Премиум') price *= 1.5;
        if(data.building_type === 'Производство') price *= 1.3;
        
        data.estimated_price = price;

        const response = await fetch('/api/quiz-save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });

        if (response.ok) {
            document.getElementById('quiz-form').style.display = 'none';
            document.getElementById('progress').parentElement.style.display = 'none';
            document.getElementById('quiz-result').style.display = 'block';
            document.getElementById('final-price').innerText = price.toLocaleString();
        }
    }
</script>

<%- include('partials/footer') %>
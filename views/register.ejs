
<% if (typeof error !== 'undefined') { %>
    <div style="background: #ffeded; color: #d93025; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;">
        <%= error %>
    </div>
<% } %>

<%- include('partials/header') %>

<main class="container" style="margin-top: 50px; display: flex; justify-content: center;">
    <div class="auth-card animate__animated animate__fadeIn">
        <h2>Регистрация</h2>
        <form action="/register" method="POST">
            <div class="form-group">
                <label>ФИО</label>
                <input type="text" name="full_name" required placeholder="Иванов Иван Иванович">
            </div>
            <div class="form-group">
    <label>Логин (английскими буквами)</label>
    <input type="text" name="username" required placeholder="ivanov99">
</div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" required placeholder="example@mail.ru">
            </div>
            <div class="form-group">
                <label>Пароль</label>
                <input type="password" name="password" required placeholder="********">
            </div>
            <button type="submit" class="btn btn-blue" style="width: 100%; margin-top: 20px;">Создать аккаунт</button>
        </form>
        <p style="margin-top: 15px; text-align: center;">
            Уже есть аккаунт? <a href="/login" style="color: var(--primary-blue);">Войти</a>
        </p>
    </div>
</main>

<%- include('partials/footer') %>